<div class="flex items-start justify-between gap-4 px-5 py-4 font-mono">
  <div class="min-w-0 flex-1">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm text-phosphor"><%= email_template.name %></span>
    </div>
    <div class="mt-1 text-xs text-cyan">
      <span class="text-phosphor-dim">domain::</span>
      <span><%= email_template.domain.name %></span>
    </div>
    <% if email_template.subject.present? %>
      <div class="mt-1 text-xs text-phosphor-dim">
        <span>subject::</span>
        <span class="text-phosphor"><%= truncate(email_template.subject, length: 70) %></span>
      </div>
    <% end %>
    <div class="mt-2 line-clamp-2 text-xs text-phosphor-dim trix-content">
      <%= email_template.body.to_s.html_safe %>
    </div>
  </div>
  <div class="flex shrink-0 items-center gap-2">
    <%= link_to "[ EDIT ]", edit_email_template_path(email_template),
        class: "border border-amber px-3 py-1 text-[0.65rem] uppercase tracking-widest text-amber hover:glow-amber" %>
    <%= button_to "[ DELETE ]", email_template_path(email_template), method: :delete,
        data: { turbo_confirm: "Delete this template?" },
        class: "border border-signal px-3 py-1 text-[0.65rem] uppercase tracking-widest text-signal hover:bg-signal hover:text-bg",
        form_class: "inline" %>
  </div>
</div>
