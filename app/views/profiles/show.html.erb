<% content_for :title, "Telex // identity" %>
<% content_for :main_class, "m-0 p-0 w-full min-h-screen bg-bg" %>

<%= render "shared/settings_shell", active: :profile, title: "Identity" do %>
  <%= render Frame::Component.new(title: "Operator record", variant: :hairline, padding: :lg) do %>
    <dl class="grid gap-5 font-mono text-sm">
      <div>
        <dt class="text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Name</dt>
        <dd class="mt-1 text-phosphor"><%= @user.name.presence || "— not set —" %></dd>
      </div>
      <div>
        <dt class="text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Email</dt>
        <dd class="mt-1 text-phosphor"><%= @user.email_address %></dd>
      </div>
      <div>
        <dt class="text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Role</dt>
        <dd class="mt-1 text-phosphor"><%= @user.admin? ? "admin :: [ root ]" : "operator" %></dd>
      </div>
    </dl>
    <div class="mt-6 flex flex-wrap gap-3 border-t border-hairline pt-5">
      <%= link_to "[ > EDIT IDENTITY ]", edit_profile_path,
          class: "border border-amber bg-amber/5 px-4 py-2 font-mono text-[0.7rem] uppercase tracking-widest text-amber hover:glow-amber" %>
      <%= button_to "[ SIGN OUT ]", session_path, method: :delete,
          class: "border border-hairline px-4 py-2 font-mono text-[0.7rem] uppercase tracking-widest text-phosphor-dim hover:border-signal hover:text-signal",
          form_class: "inline" %>
    </div>
  <% end %>
<% end %>
