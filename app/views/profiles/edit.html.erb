<% content_for :title, "Telex // edit identity" %>
<% content_for :main_class, "m-0 p-0 w-full min-h-screen bg-bg" %>

<%= render "shared/settings_shell", active: :profile, title: "Edit identity" do %>
  <%= render Frame::Component.new(title: "Modify operator record", variant: :hairline, padding: :lg) do %>
    <%= form_with model: @user, url: profile_path, method: :patch, class: "space-y-5 font-mono" do |form| %>
      <% if @user.errors.any? %>
        <div class="border border-signal bg-signal/10 px-3 py-2 text-[0.65rem] uppercase tracking-widest text-signal">
          &gt; <%= pluralize(@user.errors.count, "error") %> blocked save
          <ul class="mt-2 list-disc pl-4 text-phosphor">
            <% @user.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Name</label>
        <%= form.text_field :name, autofocus: true, autocomplete: "name", placeholder: "full name",
            class: "mt-2 block w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
      </div>

      <div>
        <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Email</label>
        <%= form.email_field :email_address, required: true, autocomplete: "email", placeholder: "operator@host.tld",
            class: "mt-2 block w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
      </div>

      <div class="flex flex-wrap items-center gap-3 border-t border-hairline pt-5">
        <%= form.submit "[ > COMMIT ]",
            class: "cursor-pointer border border-amber bg-amber/5 px-4 py-2 text-[0.7rem] uppercase tracking-widest text-amber hover:glow-amber" %>
        <%= link_to "[ CANCEL ]", profile_path,
            class: "border border-hairline px-4 py-2 text-[0.7rem] uppercase tracking-widest text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
      </div>
    <% end %>
  <% end %>
<% end %>
