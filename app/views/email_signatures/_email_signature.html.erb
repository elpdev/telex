<div class="flex items-start justify-between gap-4 px-5 py-4 font-mono">
  <div class="min-w-0 flex-1">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm text-phosphor"><%= email_signature.name %></span>
      <% if email_signature.is_default? %>
        <%= phosphor_badge("default", variant: :amber) %>
      <% end %>
    </div>
    <div class="mt-1 text-xs text-cyan">
      <span class="text-phosphor-dim">domain::</span>
      <span><%= email_signature.domain.name %></span>
    </div>
    <div class="mt-2 line-clamp-2 text-xs text-phosphor-dim trix-content">
      <%= email_signature.body.to_s.html_safe %>
    </div>
  </div>
  <div class="flex shrink-0 items-center gap-2">
    <%= link_to "[ EDIT ]", edit_email_signature_path(email_signature),
        class: "border border-amber px-3 py-1 text-[0.65rem] uppercase tracking-widest text-amber hover:glow-amber" %>
    <%= button_to "[ DELETE ]", email_signature_path(email_signature), method: :delete,
        data: { turbo_confirm: "Delete this signature?" },
        class: "border border-signal px-3 py-1 text-[0.65rem] uppercase tracking-widest text-signal hover:bg-signal hover:text-bg",
        form_class: "inline" %>
  </div>
</div>
