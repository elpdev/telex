<% form_url = folder.persisted? ? notes_folder_path(folder) : notes_folders_path %>
<% form_method = folder.persisted? ? :patch : :post %>
<%= form_with model: folder, url: form_url, method: form_method, class: "space-y-5" do |form| %>
  <% if folder.errors.any? %>
    <div class="border border-signal/60 bg-signal/10 px-4 py-3 font-mono text-xs text-signal">
      <p class="uppercase tracking-widest">Save blocked</p>
      <ul class="mt-2 space-y-1 text-phosphor">
        <% folder.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div>
    <%= form.label :name, class: "block font-mono text-[0.65rem] uppercase tracking-widest text-phosphor-dim" %>
    <%= form.text_field :name, autofocus: true, class: "mt-2 w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor focus:border-amber focus:outline-none" %>
  </div>
  <div>
    <%= form.label :parent_id, "Parent folder", class: "block font-mono text-[0.65rem] uppercase tracking-widest text-phosphor-dim" %>
    <%= form.select :parent_id, notes_folder_options, {}, class: "mt-2 w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor focus:border-amber focus:outline-none" %>
  </div>
  <div class="flex flex-wrap gap-2 font-mono text-[0.65rem] uppercase tracking-widest">
    <%= form.submit folder.persisted? ? "[ UPDATE FOLDER ]" : "[ CREATE FOLDER ]", class: "border border-amber px-4 py-2 text-amber hover:glow-amber" %>
    <%= link_to "[ CANCEL ]", @current_folder.present? ? notes_folder_path(@current_folder) : notes_path, class: "border border-hairline px-4 py-2 text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
  </div>
<% end %>
