<%= render "drives/shell", current_folder: nil, folders: [], files: @photo_files, folder_tree: @folder_tree, photos_mode: true do %>
  <div class="mb-6 flex items-end justify-between gap-4 border border-hairline bg-bg px-4 py-4">
    <div>
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.28em] text-phosphor-dim">Drive browser</p>
      <h2 class="mt-2 font-display text-3xl text-phosphor">PHOTOS</h2>
    </div>
    <div class="font-mono text-[0.65rem] uppercase tracking-widest text-phosphor-faint">
      <span><%= pluralize(@photo_files.size, "image") %></span>
    </div>
  </div>
  <%= render "drives/photos_grid", photo_files: @photo_files %>
<% end %>
