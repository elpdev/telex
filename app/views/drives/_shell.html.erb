<% content_for :title, "Telex // Drive" %>
<% content_for :main_class, "m-0 w-full px-4 pb-4 pt-6 sm:px-6 sm:pt-8" %>
<div class="grid min-h-[calc(100vh-6rem)] gap-4 xl:grid-cols-[16rem_minmax(0,1fr)]">
  <aside class="border border-hairline bg-bg-2 p-4">
    <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">&gt; drive kernel</p>
    <h1 class="mt-3 font-display text-3xl text-phosphor glow-phosphor">DRIVE</h1>
    <div class="mt-6 flex flex-wrap gap-2 font-mono text-[0.65rem] uppercase tracking-widest">
      <%= link_to "[ + FOLDER ]", new_drives_folder_path(parent_id: current_folder&.id), class: "border border-amber px-3 py-1 text-amber hover:glow-amber" %>
      <%= link_to "[ + UPLOAD ]", new_drives_file_path(folder_id: current_folder&.id), class: "border border-phosphor px-3 py-1 text-phosphor hover:glow-phosphor" %>
    </div>
    <div class="mt-8 border-t border-hairline pt-4">
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.28em] text-phosphor-dim">Apps</p>
      <div class="mt-4">
        <%= render "shared/app_switcher" %>
      </div>
    </div>
    <nav class="mt-8 flex flex-wrap gap-2 border-t border-hairline pt-4 font-mono text-[0.65rem] uppercase tracking-widest">
      <%= link_to "[ ROOT ]", drive_path, class: token_list("border px-3 py-1", current_folder.nil? && !local_assigns.fetch(:photos_mode, false) ? "border-amber text-amber glow-amber" : "border-hairline text-phosphor-dim hover:border-phosphor hover:text-phosphor") %>
      <%= link_to "[ PHOTOS ]", drives_photos_path, class: token_list("border px-3 py-1", local_assigns.fetch(:photos_mode, false) ? "border-amber text-amber glow-amber" : "border-hairline text-phosphor-dim hover:border-phosphor hover:text-phosphor") %>
      <% if current_folder.present? %>
        <%= link_to "[ EDIT ]", edit_drives_folder_path(current_folder), class: "border border-hairline px-3 py-1 text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
      <% end %>
    </nav>
    <div class="mt-8 border-t border-hairline pt-4">
      <p class="font-mono text-[0.62rem] uppercase tracking-[0.28em] text-phosphor-dim">Folder map</p>
      <div class="mt-4 space-y-2">
        <% if folder_tree.blank? || folder_tree.values.flatten.empty? %>
          <p class="border border-dashed border-hairline px-3 py-3 font-mono text-xs text-phosphor-faint">No folders at root.</p>
        <% else %>
          <%= render "drives/folder_tree", nodes: drive_folder_tree(folder_tree, current_folder) %>
        <% end %>
      </div>
    </div>
  </aside>
  <section class="flex min-h-0 flex-col border border-hairline bg-bg-2">
    <div class="flex flex-wrap items-center justify-between gap-3 border-b border-hairline px-4 py-3 font-mono text-[0.65rem] uppercase tracking-[0.25em] text-phosphor-dim">
      <div class="flex items-center gap-2">
        <span class="border border-hairline px-2 py-1">[ <%= local_assigns.fetch(:photos_mode, false) ? "PHOTOS" : (current_folder.present? ? current_folder.name.upcase : "ROOT") %> ]</span>
        <span class="text-phosphor-faint">[ <%= pluralize(folders.size, "folder") %> / <%= pluralize(files.size, "file") %> ]</span>
      </div>
      <div class="flex items-center gap-2 text-phosphor-faint">
        <span><%= current_folder.present? ? drive_source_label(current_folder) : "LOCAL ROOT" %></span>
      </div>
    </div>
    <div class="min-h-0 flex-1 p-4">
      <%= yield %>
    </div>
    <div class="flex items-center justify-between border-t border-hairline bg-bg px-4 py-2 font-mono text-[0.6rem] uppercase tracking-widest text-phosphor-faint">
      <div class="flex items-center gap-4">
        <span><span class="text-phosphor">cmd+k</span> palette</span>
        <span><span class="text-phosphor">+</span> folder</span>
        <span><span class="text-phosphor">u</span> upload</span>
        <span><span class="text-phosphor">enter</span> open</span>
      </div>
      <div class="flex items-center gap-3">
        <span class="text-phosphor-dim">[ OPERATOR :: <%= Current.user&.email_address %> ]</span>
        <span class="text-moss">[ ONLINE ]</span>
      </div>
    </div>
  </section>
</div>
