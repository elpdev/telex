<% if photo_files.empty? %>
  <div class="border border-dashed border-hairline bg-bg px-4 py-8 font-mono text-xs text-phosphor-faint">
    No photos yet. Upload image files into Drive to build this view.
  </div>
<% else %>
  <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
    <% photo_files.each do |stored_file| %>
      <article class="overflow-hidden border border-hairline bg-bg">
        <div class="aspect-square border-b border-hairline bg-bg-3">
          <% if drive_previewable_image?(stored_file) %>
            <%= link_to download_drives_file_path(stored_file) do %>
              <%= drive_preview_image_tag(stored_file, size: [480, 480], class_name: "h-full w-full object-cover") %>
            <% end %>
          <% else %>
            <div class="flex h-full items-center justify-center font-mono text-xs uppercase tracking-[0.3em] text-phosphor-faint">
              No preview
            </div>
          <% end %>
        </div>
        <div class="space-y-3 px-4 py-4 font-mono text-xs">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="text-phosphor"><%= stored_file.filename %></p>
              <p class="mt-1 text-phosphor-faint"><%= drive_source_label(stored_file) %></p>
            </div>
            <span class="border px-2 py-1 uppercase tracking-widest <%= drive_preview_chip_class(stored_file) %>"><%= drive_preview_badge(stored_file) %></span>
          </div>
          <div class="flex items-center justify-between text-phosphor-faint">
            <span><%= drive_size_label(stored_file) %></span>
            <span><%= drive_updated_label(stored_file) %></span>
          </div>
          <div class="flex flex-wrap gap-2 uppercase tracking-widest">
            <% if stored_file.downloadable? %>
              <%= link_to "[ DOWNLOAD ]", download_drives_file_path(stored_file), class: "text-phosphor-dim hover:text-phosphor" %>
            <% end %>
            <%= link_to "[ EDIT ]", edit_drives_file_path(stored_file), class: "text-phosphor-dim hover:text-phosphor" %>
            <% if stored_file.folder.present? %>
              <%= link_to "[ FOLDER ]", drives_folder_path(stored_file.folder), class: "text-phosphor-dim hover:text-phosphor" %>
            <% end %>
          </div>
        </div>
      </article>
    <% end %>
  </div>
<% end %>
