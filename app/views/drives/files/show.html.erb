<%= render "drives/shell", current_folder: @current_folder, folders: [], files: [@stored_file], folder_tree: @folder_tree do %>
  <%= render "drives/breadcrumb", breadcrumb_folders: @breadcrumb_folders %>
  <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_20rem]">
    <section class="overflow-hidden border border-hairline bg-bg">
      <div class="flex items-center justify-between border-b border-hairline px-4 py-3 font-mono text-[0.65rem] uppercase tracking-widest text-phosphor-dim">
        <span>[ PREVIEW ]</span>
        <span><%= drive_preview_badge(@stored_file) %></span>
      </div>
      <div class="min-h-[26rem] bg-bg-3 p-4">
        <% case @preview_kind %>
        <% when :image %>
          <div class="flex h-full items-center justify-center">
            <%= drive_preview_image_tag(@stored_file, size: [1400, 1400], class_name: "max-h-[70vh] w-auto border border-hairline object-contain") %>
          </div>
        <% when :video %>
          <div class="flex h-full items-center justify-center">
            <%= drive_preview_video_tag(@stored_file, class_name: "max-h-[70vh] w-full", controls: true) %>
          </div>
        <% when :pdf %>
          <iframe src="<%= drive_inline_blob_url(@stored_file) %>" class="h-[70vh] w-full border border-hairline bg-bg" title="<%= @stored_file.filename %>"></iframe>
        <% when :audio %>
          <div class="flex h-full items-center justify-center">
            <audio controls class="w-full max-w-2xl">
              <source src="<%= drive_inline_blob_url(@stored_file) %>" type="<%= @stored_file.mime_type %>">
            </audio>
          </div>
        <% when :markdown %>
          <div class="h-[70vh] overflow-auto border border-hairline bg-bg px-5 py-5">
            <%= render Markdown::Component.new(text: drive_text_preview(@stored_file), extra_classes: "max-w-none prose-invert prose-headings:text-phosphor prose-p:text-phosphor prose-strong:text-phosphor") %>
          </div>
        <% when :text %>
          <pre class="h-[70vh] overflow-auto border border-hairline bg-bg px-4 py-4 font-mono text-xs leading-6 text-phosphor"><%= drive_text_preview(@stored_file) %></pre>
        <% else %>
          <div class="flex h-full items-center justify-center font-mono text-xs uppercase tracking-[0.3em] text-phosphor-faint">
            No inline preview. Use download to inspect locally.
          </div>
        <% end %>
      </div>
    </section>
    <aside class="border border-hairline bg-bg px-4 py-4">
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.28em] text-phosphor-dim">File detail</p>
      <h2 class="mt-3 break-all font-display text-2xl text-phosphor"><%= @stored_file.filename %></h2>
      <dl class="mt-6 space-y-3 font-mono text-xs">
        <div class="flex items-start justify-between gap-3">
          <dt class="text-phosphor-dim">Status</dt>
          <dd class="text-phosphor"><%= drive_status_label(@stored_file) %></dd>
        </div>
        <div class="flex items-start justify-between gap-3">
          <dt class="text-phosphor-dim">Source</dt>
          <dd class="text-phosphor"><%= drive_source_label(@stored_file) %></dd>
        </div>
        <div class="flex items-start justify-between gap-3">
          <dt class="text-phosphor-dim">Size</dt>
          <dd class="text-phosphor"><%= drive_size_label(@stored_file) %></dd>
        </div>
        <div class="flex items-start justify-between gap-3">
          <dt class="text-phosphor-dim">Updated</dt>
          <dd class="text-phosphor"><%= drive_updated_label(@stored_file) %></dd>
        </div>
        <div class="flex items-start justify-between gap-3">
          <dt class="text-phosphor-dim">Folder</dt>
          <dd class="text-phosphor"><%= @stored_file.folder&.name || "ROOT" %></dd>
        </div>
        <% if @stored_file.drive_albums.any? %>
          <div class="flex items-start justify-between gap-3">
            <dt class="text-phosphor-dim">Albums</dt>
            <dd class="text-right text-phosphor"><%= @stored_file.drive_albums.order(:name).map(&:name).join(", ") %></dd>
          </div>
        <% end %>
      </dl>
      <div class="mt-6 flex flex-wrap gap-2 font-mono text-[0.65rem] uppercase tracking-widest">
        <% if @stored_file.downloadable? %>
          <%= link_to "[ DOWNLOAD ]", download_drives_file_path(@stored_file), class: "border border-phosphor px-3 py-1 text-phosphor hover:glow-phosphor" %>
        <% end %>
        <%= link_to "[ MOVE ]", edit_drives_file_path(@stored_file), class: "border border-hairline px-3 py-1 text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
        <%= link_to "[ BACK ]", drive_root_path_for(@stored_file.folder), class: "border border-hairline px-3 py-1 text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
      </div>
    </aside>
  </div>
<% end %>
