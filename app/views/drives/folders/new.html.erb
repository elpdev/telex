<%= render "drives/shell", current_folder: @current_folder, folders: [], files: [], folder_tree: @folder_tree do %>
  <%= render "drives/breadcrumb", breadcrumb_folders: @breadcrumb_folders %>
  <div class="mx-auto max-w-3xl border border-hairline bg-bg px-6 py-6">
    <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">&gt; create folder</p>
    <h2 class="mt-3 font-display text-3xl text-phosphor">NEW FOLDER</h2>
    <div class="mt-6">
      <%= render "form", folder: @folder, current_folder: @current_folder %>
    </div>
  </div>
<% end %>
