<%= render "calendars/shell",
  calendars: calendars_scope.to_a,
  selected_calendar_ids: [@event.calendar_id],
  current_date: @event.starts_at.to_date,
  active_view: "agenda" do %>
  <div class="grid gap-4 xl:grid-cols-[minmax(0,1fr)_20rem]">
    <section class="border border-hairline bg-bg px-6 py-6">
      <div class="flex flex-wrap items-center justify-between gap-3">
        <div>
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">&gt; event detail</p>
          <h2 class="mt-3 font-display text-4xl text-phosphor"><%= @event.title.upcase %></h2>
        </div>
        <div class="flex gap-2 font-mono text-[0.65rem] uppercase tracking-widest">
          <%= link_to "[ EDIT ]", edit_calendars_event_path(@event), class: "border border-hairline px-3 py-1 text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
          <%= button_to "[ DELETE ]", calendars_event_path(@event), method: :delete, class: "border border-signal px-3 py-1 text-signal hover:bg-signal hover:text-bg", form_class: "inline" %>
        </div>
      </div>
      <dl class="mt-8 grid gap-3 font-mono text-sm">
        <div class="grid gap-1 border-b border-hairline pb-3 md:grid-cols-[10rem_minmax(0,1fr)]">
          <dt class="text-phosphor-dim">Calendar</dt>
          <dd><%= phosphor_badge(@event.calendar.name, variant: :cyan, preserve_case: true) %></dd>
        </div>
        <div class="grid gap-1 border-b border-hairline pb-3 md:grid-cols-[10rem_minmax(0,1fr)]">
          <dt class="text-phosphor-dim">Time</dt>
          <dd class="text-phosphor"><%= @event.all_day ? @event.starts_at.to_date.strftime("%b %d, %Y") : "#{@event.starts_at.strftime('%b %d, %Y %H:%M')} -> #{@event.ends_at.strftime('%b %d, %Y %H:%M')}" %></dd>
        </div>
        <div class="grid gap-1 border-b border-hairline pb-3 md:grid-cols-[10rem_minmax(0,1fr)]">
          <dt class="text-phosphor-dim">Repeats</dt>
          <dd class="text-phosphor"><%= @event.recurrence_summary %></dd>
        </div>
        <% if @event.location.present? %>
          <div class="grid gap-1 border-b border-hairline pb-3 md:grid-cols-[10rem_minmax(0,1fr)]">
            <dt class="text-phosphor-dim">Location</dt>
            <dd class="text-phosphor"><%= @event.location %></dd>
          </div>
        <% end %>
        <% if @event.organizer_email.present? %>
          <div class="grid gap-1 border-b border-hairline pb-3 md:grid-cols-[10rem_minmax(0,1fr)]">
            <dt class="text-phosphor-dim">Organizer</dt>
            <dd class="text-phosphor"><%= [@event.organizer_name, @event.organizer_email].compact.join(" :: ") %></dd>
          </div>
        <% end %>
        <% if @event.description.present? %>
          <div class="grid gap-1 md:grid-cols-[10rem_minmax(0,1fr)]">
            <dt class="text-phosphor-dim">Description</dt>
            <dd class="whitespace-pre-wrap text-phosphor"><%= @event.description %></dd>
          </div>
        <% end %>
        <% if @event.calendar_event_attendees.any? %>
          <div class="grid gap-2 border-t border-hairline pt-3 md:grid-cols-[10rem_minmax(0,1fr)]">
            <dt class="text-phosphor-dim">Attendees</dt>
            <dd class="space-y-2">
              <% @event.calendar_event_attendees.order(:email).each do |attendee| %>
                <div class="flex flex-wrap items-center gap-2 text-phosphor">
                  <span><%= attendee.name.presence || attendee.email %></span>
                  <% if attendee.name.present? %>
                    <span class="text-phosphor-dim"><%= attendee.email %></span>
                  <% end %>
                  <%= phosphor_badge(attendee.participation_status.tr("_", " "), variant: attendee.accepted? ? :moss : (attendee.tentative? ? :amber : (attendee.declined? ? :signal : :dim))) %>
                </div>
              <% end %>
            </dd>
          </div>
        <% end %>
      </dl>
      <% if @invitation_links.any? %>
        <section class="mt-8 border-t border-hairline pt-5">
          <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">&gt; invitation emails</p>
          <div class="mt-4 space-y-2">
            <% @invitation_links.each do |link| %>
              <% linked_message = link.message %>
              <%= link_to root_path(inbox_id: linked_message.inbox_id, message_id: linked_message.id), class: "block border border-hairline px-3 py-3 font-mono text-xs text-phosphor hover:border-phosphor" do %>
                <div class="flex items-start justify-between gap-3">
                  <div>
                    <p class="text-phosphor"><%= linked_message.subject.presence || "(no subject)" %></p>
                    <p class="mt-1 text-phosphor-dim"><%= linked_message.inbox.address %> :: <%= linked_message.sender_display %></p>
                  </div>
                  <span class="text-phosphor-faint"><%= mono_timestamp(linked_message.received_at) %></span>
                </div>
              <% end %>
            <% end %>
          </div>
        </section>
      <% end %>
    </section>
    <aside class="border border-hairline bg-bg px-4 py-4">
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">&gt; upcoming</p>
      <div class="mt-4 space-y-2">
        <% @next_occurrences.each do |occurrence| %>
          <div class="border border-hairline px-3 py-2 font-mono text-xs text-phosphor">
            <p><%= occurrence.strftime("%b %d, %Y") %></p>
            <% unless @event.all_day %>
              <p class="mt-1 text-phosphor-dim"><%= occurrence.strftime("%H:%M") %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    </aside>
  </div>
<% end %>
