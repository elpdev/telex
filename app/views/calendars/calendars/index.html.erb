<%= render "calendars/shell",
  calendars: @calendars.to_a,
  selected_calendar_ids: @calendars.map(&:id),
  current_date: Time.zone.today,
  active_view: "month" do %>
  <div class="border border-hairline bg-bg px-6 py-6">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">&gt; local calendars</p>
        <h2 class="mt-3 font-display text-3xl text-phosphor">CALENDARS</h2>
      </div>
      <%= link_to "[ NEW CALENDAR ]", new_calendars_calendar_path, class: "border border-amber px-3 py-2 font-mono text-[0.65rem] uppercase tracking-widest text-amber hover:glow-amber" %>
    </div>
    <div class="mt-6 space-y-3">
      <% @calendars.each do |calendar| %>
        <div class="flex items-center justify-between gap-4 border border-hairline px-4 py-3">
          <div>
            <p class="font-mono text-sm uppercase tracking-wider text-phosphor"><%= calendar.name %></p>
            <p class="mt-1 font-mono text-[0.68rem] uppercase tracking-widest text-phosphor-dim"><%= calendar.time_zone %> :: <%= pluralize(calendar.calendar_events.count, "event") %></p>
          </div>
          <div class="flex items-center gap-2 font-mono text-[0.65rem] uppercase tracking-widest">
            <%= phosphor_badge(calendar.color, variant: :dim, preserve_case: true) %>
            <%= link_to "[ EDIT ]", edit_calendars_calendar_path(calendar), class: "border border-hairline px-3 py-1 text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
