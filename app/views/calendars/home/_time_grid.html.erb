<% days = calendar_time_grid_days(view_mode, current_date) %>
<% if occurrences.empty? %>
  <div class="border border-dashed border-hairline px-6 py-10 font-mono text-xs uppercase tracking-widest text-phosphor-dim">
    no scheduled events in this window
  </div>
<% else %>
  <div class="flex h-full min-h-0 flex-col border border-hairline bg-bg">
    <div class="grid border-b border-hairline bg-bg-2" style="grid-template-columns: 4.5rem repeat(<%= days.length %>, minmax(0, 1fr));">
      <div class="border-r border-hairline px-3 py-3 font-mono text-[0.62rem] uppercase tracking-[0.25em] text-phosphor-dim">
        utc
      </div>
      <% days.each do |day| %>
        <div class="border-r border-hairline px-3 py-3 last:border-r-0">
          <div class="font-mono text-[0.62rem] uppercase tracking-[0.25em] text-phosphor-dim"><%= calendar_day_label(day, condensed: view_mode == "week") %></div>
          <div class="mt-1 text-xl text-phosphor"><%= calendar_day_number_label(day) %></div>
          <% all_day_occurrences = calendar_all_day_occurrences(occurrences, day) %>
          <div class="mt-3 space-y-1">
            <% if all_day_occurrences.any? %>
              <% all_day_occurrences.each do |occurrence| %>
                <%= link_to calendars_event_path(occurrence.event), class: "block border px-2 py-1 font-mono text-[0.62rem] uppercase tracking-wider hover:bg-bg", style: "border-color: currentColor;" do %>
                  <div class="truncate <%= calendar_color_class(occurrence.event.calendar) %>"><%= occurrence.event.title %></div>
                  <div class="truncate text-phosphor-faint">ALL DAY</div>
                <% end %>
              <% end %>
            <% else %>
              <div class="font-mono text-[0.58rem] uppercase tracking-widest text-phosphor-faint">no all-day events</div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
    <div class="grid min-h-0 flex-1 overflow-auto" style="grid-template-columns: 4.5rem repeat(<%= days.length %>, minmax(0, 1fr));">
      <div class="border-r border-hairline bg-bg-2">
        <% calendar_hour_labels.each do |hour_label| %>
          <div class="relative h-16 border-b border-hairline px-3 pt-1 font-mono text-[0.58rem] uppercase tracking-widest text-phosphor-faint last:border-b-0">
            <%= hour_label %>
          </div>
        <% end %>
      </div>
      <% days.each do |day| %>
        <% timed_segments = calendar_time_grid_segments(occurrences, day) %>
        <div class="relative border-r border-hairline last:border-r-0">
          <% 24.times do %>
            <div class="h-16 border-b border-hairline/80 last:border-b-0"></div>
          <% end %>
          <% timed_segments.each do |segment| %>
            <%= link_to calendars_event_path(segment.occurrence.event), class: "absolute z-10 overflow-hidden border bg-bg/95 px-2 py-1 font-mono text-[0.58rem] uppercase tracking-wider hover:bg-bg-2", style: "#{calendar_segment_style(segment)} border-color: currentColor;" do %>
              <div class="truncate <%= calendar_color_class(segment.occurrence.event.calendar) %>"><%= segment.occurrence.event.title %></div>
              <div class="truncate text-phosphor-dim"><%= calendar_segment_time_range(segment) %></div>
              <% if segment.occurrence.event.location.present? %>
                <div class="truncate text-phosphor-faint"><%= segment.occurrence.event.location %></div>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
