<% content_for :title, "Telex // operator console" %>
<div class="relative min-h-screen w-full overflow-hidden bg-bg text-phosphor">
  <%# Subtle grid background %>
  <div class="grid-bg pointer-events-none absolute inset-0 opacity-40"></div>
  <%# Top status bar %>
  <div class="relative z-10 flex items-center justify-between border-b border-hairline px-6 py-3 font-mono text-[0.65rem] uppercase tracking-widest">
    <div class="flex items-center gap-4">
      <%= render Logo::Component.new(size: :xs) %>
      <span class="hidden text-phosphor-dim sm:inline">v0.3 :: public</span>
      <span class="hidden text-moss sm:inline">[ ONLINE ]</span>
    </div>
    <div class="flex items-center gap-4">
      <%= link_to "[ SIGN IN ]", new_session_path, class: "text-phosphor hover:glow-phosphor" %>
      <% if Flipper.enabled?(:sign_up) %>
        <%= link_to "[ REGISTER ]", new_registration_path, class: "border border-amber px-3 py-1 text-amber hover:glow-amber" %>
      <% end %>
    </div>
  </div>
  <%# Hero %>
  <section class="relative z-10 mx-auto max-w-6xl px-6 pt-16 pb-24 md:pt-24">
    <p class="font-mono text-[0.7rem] uppercase tracking-[0.35em] text-phosphor-dim">
      &gt; boot ok :: awaiting operator<span class="blink text-amber">_</span>
    </p>
    <h1 class="mt-8 font-display text-[clamp(2.4rem,6.5vw,5.5rem)] font-normal leading-[0.95] tracking-tight text-phosphor">
      <span class="block glow-phosphor">THE OPERATIONAL</span>
      <span class="block text-amber glow-amber">INBOX</span>
      <span class="block">FOR YOU AND</span>
      <span class="block text-phosphor-dim">YOUR AGENTS.</span>
    </h1>
    <p class="mt-10 max-w-2xl font-mono text-sm leading-relaxed text-phosphor-dim">
      Self-hosted. Multi-domain. Agent-ready. A terminal for every email address you run &mdash;
      where AI agents classify, draft, and respond alongside you, and you keep the final word.
    </p>
    <div class="mt-10 flex flex-wrap items-center gap-3 font-mono text-xs uppercase tracking-widest">
      <% if Flipper.enabled?(:sign_up) %>
        <%= link_to new_registration_path, class: "border border-amber bg-amber/5 px-5 py-3 text-amber hover:glow-amber" do %>
          [ &gt; START SESSION ]
        <% end %>
      <% end %>
      <%= link_to new_session_path, class: "border border-phosphor px-5 py-3 text-phosphor hover:glow-phosphor" do %>
        [ SIGN IN ]
      <% end %>
      <a href="#manifesto" class="ml-2 text-phosphor-dim underline-offset-4 hover:text-phosphor hover:underline">
        read the manifesto ↓
      </a>
    </div>
  </section>
  <%# ASCII live-mockup of the inbox %>
  <section class="relative z-10 mx-auto max-w-6xl px-6 pb-16">
    <div class="border border-hairline bg-bg-2 font-mono text-[0.72rem] leading-relaxed">
      <div class="flex items-center justify-between border-b border-hairline px-4 py-2 text-[0.62rem] uppercase tracking-widest text-phosphor-dim">
        <span>/telex/feed</span>
        <span>[ &middot; ] [ - ] [ X ]</span>
      </div>
      <div class="grid gap-0 md:grid-cols-[3rem_minmax(0,1fr)_minmax(0,1.3fr)]">
        <div class="hidden flex-col items-center gap-2 border-r border-hairline bg-bg py-4 md:flex">
          <span class="text-amber">[INB]</span>
          <span class="text-phosphor-dim">[OUT]</span>
          <span class="text-phosphor-dim">[DFT]</span>
          <span class="text-phosphor-dim">[ARC]</span>
          <span class="text-phosphor-dim">[TRH]</span>
        </div>
        <div class="border-r border-hairline bg-bg">
          <div class="border-b border-hairline px-3 py-2 text-phosphor">
            &gt; [INBOX] :: hello@lbp.dev <span class="blink text-amber">_</span>
          </div>
          <div class="divide-y divide-hairline">
            <div class="flex items-baseline gap-2 border-l-2 border-amber bg-amber/10 px-3 py-2">
              <span class="text-phosphor-faint">01</span>
              <span class="text-amber">*</span>
              <span class="text-phosphor-dim">14:32</span>
              <span class="text-phosphor">a.hale</span>
              <span class="text-amber text-[0.58rem] border border-amber px-1">AGT</span>
            </div>
            <div class="flex items-baseline gap-2 border-l-2 border-phosphor-dim px-3 py-2">
              <span class="text-phosphor-faint">02</span>
              <span class="text-amber">&middot;</span>
              <span class="text-phosphor-dim">11:04</span>
              <span class="text-phosphor-dim">j.doe</span>
            </div>
            <div class="flex items-baseline gap-2 px-3 py-2">
              <span class="text-phosphor-faint">03</span>
              <span>&nbsp;</span>
              <span class="text-phosphor-dim">09:21</span>
              <span class="text-phosphor-dim">stripe&lt;noreply@&gt;</span>
            </div>
          </div>
        </div>
        <div class="bg-bg">
          <div class="border-b border-hairline px-4 py-3">
            <p class="text-[0.62rem] uppercase tracking-widest text-phosphor-dim">&gt; thread :: hello@lbp.dev</p>
            <p class="mt-1 font-display text-lg text-phosphor glow-phosphor">Weekly sync notes</p>
          </div>
          <div class="space-y-2 px-4 py-3 text-phosphor-dim">
            <p><span class="text-phosphor-faint">FROM</span> &nbsp; anna hale &lt;a.hale@acme.co&gt;</p>
            <p><span class="text-phosphor-faint">RECEIVED</span> 2026-04-10 14:32</p>
            <p class="pt-2 text-phosphor">&gt; here are the action items for the sprint:</p>
            <p class="text-phosphor">&gt; 1. ship the new observability dashboard</p>
            <p class="text-phosphor">&gt; 2. review the agent safety doc</p>
            <p class="text-phosphor">&gt; 3. the new inbox ui landed. lets ship it.</p>
          </div>
          <div class="border-t border-hairline bg-bg-2 px-4 py-3">
            <p class="text-phosphor"><span class="text-phosphor-dim">&gt;</span> COMPOSE :: reply to a.hale@acme.co<span class="blink text-amber">_</span></p>
          </div>
        </div>
      </div>
    </div>
    <p class="mt-4 text-center font-mono text-[0.6rem] uppercase tracking-[0.3em] text-phosphor-faint">
      / live preview &middot; rendered from the actual ui /
    </p>
  </section>
  <%# Feature strip %>
  <section class="relative z-10 border-t border-hairline">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-0 border-hairline md:grid-cols-2 md:divide-x md:divide-hairline lg:grid-cols-4">
      <% features = [
        {tag: "01", title: "MULTI-DOMAIN", body: "Run support@, hello@, billing@ across every domain you own, from one operator console."},
        {tag: "02", title: "AGENT-READY", body: "JWT-secured REST API for every action. Agents can read, draft, archive, and label alongside you."},
        {tag: "03", title: "CONVERSATION MIND", body: "Threads auto-stitch inbound and outbound via header + subject, always preserving the full timeline."},
        {tag: "04", title: "VIM-INSPIRED KEYS", body: "j/k to navigate, g-prefixed mailbox jumps, r/a/f/e/# to act, cmd+k for the palette. Your hands never leave home row."}
      ] %>
      <% features.each do |f| %>
        <div class="border-t border-hairline p-6 md:border-t-0 md:border-b-0 lg:first:border-l-0">
          <p class="font-mono text-[0.6rem] uppercase tracking-[0.3em] text-phosphor-faint"><%= f[:tag] %> //</p>
          <h3 class="mt-2 font-display text-xl text-phosphor"><%= f[:title] %></h3>
          <p class="mt-3 font-mono text-xs leading-relaxed text-phosphor-dim"><%= f[:body].html_safe %></p>
        </div>
      <% end %>
    </div>
  </section>
  <%# Manifesto %>
  <section id="manifesto" class="relative z-10 border-t border-hairline">
    <div class="mx-auto max-w-3xl px-6 py-20">
      <p class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">&gt; /manifesto</p>
      <div class="mt-6 space-y-5 font-display text-xl italic leading-relaxed text-phosphor">
        <p>&ldquo; email is infrastructure.</p>
        <p>the tools that run on top of it should feel like infrastructure too.</p>
        <p>not a chat app with hearts and threads, not a pastel feed with emoji reactions,</p>
        <p class="text-amber">a console. a terminal. a signal processor.</p>
        <p>every message is a packet.</p>
        <p>every agent is a worker.</p>
        <p>every inbox is a listening socket.</p>
        <p class="text-phosphor-dim">you are the operator.&rdquo;</p>
      </div>
      <p class="mt-6 font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-faint">Claude</p>
      <div class="mt-10 flex items-center gap-4 font-mono text-xs uppercase tracking-widest">
        <% if Flipper.enabled?(:sign_up) %>
          <%= link_to "[ &gt; START SESSION ]".html_safe, new_registration_path,
              class: "border border-amber bg-amber/5 px-5 py-3 text-amber hover:glow-amber" %>
          <span class="blink text-amber">_</span>
        <% end %>
      </div>
    </div>
  </section>
  <%# Footer %>
  <footer class="relative z-10 border-t border-hairline">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5 font-mono text-[0.6rem] uppercase tracking-widest text-phosphor-faint">
      <div>&copy; <%= Date.current.year %> Telex :: self-hosted</div>
      <div class="flex items-center gap-4">
        <span>[ BUILT WITH RAILS ]</span>
        <span>[ MIT ]</span>
      </div>
    </div>
  </footer>
</div>
