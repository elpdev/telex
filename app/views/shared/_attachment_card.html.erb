<div class="border bg-bg-2 px-4 py-3 font-mono text-xs <%= selected ? 'border-amber' : 'border-hairline' %>">
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0">
      <p class="truncate text-phosphor"><%= attachment.filename %></p>
      <p class="mt-1 text-[0.65rem] uppercase tracking-wider text-phosphor-faint"><%= attachment_display_content_type(attachment) %> &middot; <%= number_to_human_size(attachment.byte_size) %></p>
      <% unless attachment_previewable?(attachment) %>
        <p class="mt-2 text-[0.65rem] uppercase tracking-wider text-amber">Preview unavailable for this file type</p>
      <% end %>
    </div>
    <div class="flex shrink-0 flex-wrap items-center justify-end gap-2">
      <% if attachment_previewable?(attachment) && preview_select_path.present? %>
        <%= link_to(selected ? "[ Previewing ]" : "[ Preview ]", preview_select_path, class: "border #{selected ? 'border-amber text-amber' : 'border-hairline text-phosphor-dim hover:border-phosphor hover:text-phosphor'} px-2 py-0.5 uppercase tracking-wider") %>
      <% end %>
      <%= link_to "[ Download ]", download_path, class: "border border-phosphor bg-phosphor/5 px-2 py-0.5 uppercase tracking-wider text-phosphor hover:border-amber hover:text-amber" %>
    </div>
  </div>
</div>
