<%#
  Status bar :: bottom-fixed strip showing contextual keybinds and a scope
  breadcrumb. Product-area-aware: shows different shortcuts per app.
%>
<% shortcuts = case current_product_area
  when :calendar
    [["m", "month"], ["w", "week"], ["d", "day"], ["a", "agenda"], ["n", "new event"], ["i", "import"]]
  when :drive
    [["cmd+k", "palette"], ["+", "folder"], ["u", "upload"], ["enter", "open"]]
  else
    [["j/k", "nav"], ["c", "compose"], ["r", "reply"], ["e", "archive"], ["#", "trash"], ["cmd+k", "palette"], ["?", "help"]]
  end
%>
<div class="flex h-7 shrink-0 items-center justify-between border-t border-hairline bg-bg-2 px-4 font-mono text-[0.6rem] uppercase tracking-widest text-phosphor-faint">
  <div class="flex items-center gap-4">
    <% shortcuts.each_with_index do |pair, i| %>
      <span<%= i >= 5 ? ' class="hidden md:inline"'.html_safe : '' %>><span class="text-phosphor"><%= pair[0] %></span> <%= pair[1] %></span>
    <% end %>
  </div>
  <div class="flex items-center gap-3">
    <span class="text-phosphor-dim">[ OPERATOR :: <%= Current.user&.email_address %> ]</span>
    <span class="text-moss">[ ONLINE ]</span>
    <span class="blink text-amber">_</span>
  </div>
</div>
