<div class="mt-4 border border-hairline bg-bg-2">
  <div class="border-b border-hairline px-4 py-2 font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">
    [ Attachment preview ]
  </div>
  <div class="border-b border-hairline bg-bg px-4 py-2 font-mono text-xs text-phosphor">
    <%= attachment.filename %>
  </div>
  <% case attachment_preview_kind(attachment) %>
  <% when :image %>
    <div class="bg-bg-3 p-4">
      <%= image_tag preview_url, alt: attachment.filename.to_s, class: "mx-auto max-h-[32rem] w-auto border border-hairline" %>
    </div>
  <% when :pdf %>
    <iframe
      src="<%= preview_url %>"
      title="Preview for <%= attachment.filename %>"
      class="block min-h-[32rem] w-full bg-white"
      referrerpolicy="no-referrer"
    ></iframe>
  <% else %>
    <div class="px-4 py-6 font-mono text-xs text-phosphor-dim">
      &gt; preview unavailable for this attachment :: use download to open locally_
    </div>
  <% end %>
</div>
