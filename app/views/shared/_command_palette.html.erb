<%#
  Command palette :: Cmd+K
  Opens a terminal-style modal with a prompt input. Built-in suggestions
  include mailbox jumps, channel filters, label filters, and a small set
  of actions (archive, trash, etc) that post to the server when selected.
%>
<% commands = command_palette_commands %>
<div class="pointer-events-none fixed inset-0 z-[9000] hidden items-start justify-center pt-[18vh]"
     data-command-palette-target="overlay"
     data-action="click->command-palette#backdropClick">
  <div class="pointer-events-auto w-full max-w-2xl border border-phosphor bg-bg text-phosphor glow-box-phosphor"
       data-command-palette-target="dialog"
         role="dialog"
         aria-label="Command palette">
    <div class="flex items-center justify-between border-b border-hairline px-4 py-2 font-mono text-[0.65rem] uppercase tracking-widest">
      <span class="text-phosphor-dim">[ CMD ]</span>
      <span class="text-phosphor-faint">ESC :: DISMISS &nbsp;/&nbsp; ENTER :: EXEC &nbsp;/&nbsp; ↑↓ :: MOVE</span>
    </div>
    <div class="flex items-center justify-between border-b border-hairline px-4 py-2 font-mono text-[0.65rem] uppercase tracking-[0.28em] text-phosphor-dim">
      <span data-command-palette-target="breadcrumb">ROOT</span>
      <span class="text-phosphor-faint">&larr; :: BACK &nbsp;/&nbsp; BKSP :: UP</span>
    </div>
    <div class="flex items-center gap-2 border-b border-hairline px-4 py-3 font-mono text-sm">
      <span class="text-amber">&gt;</span>
      <input type="text"
             placeholder="navigate commands _"
              class="w-full bg-transparent font-mono text-sm uppercase tracking-wider text-phosphor placeholder:text-phosphor-faint focus:outline-none"
              data-command-palette-target="input"
              data-action="input->command-palette#filter keydown->command-palette#navigate"
      autocomplete="off"
      spellcheck="false" />
    </div>
    <ul class="max-h-[40vh] overflow-y-auto font-mono text-xs"
        data-command-palette-target="list">
      <% commands.each_with_index do |command, i| %>
        <li class="<%= i.zero? ? 'bg-bg-3' : '' %>"
            data-command-palette-target="item"
            data-kind="node"
            data-node-id="<%= command[:id] %>"
            data-label="<%= command[:label] %>"
            data-hint="<%= command[:hint] %>">
          <button type="button"
             class="flex w-full items-center justify-between gap-4 px-4 py-2 text-left text-phosphor hover:bg-bg-3 hover:text-amber"
             data-action="click->command-palette#select">
            <span class="flex items-center gap-2">
              <span class="text-phosphor-dim">&gt;</span>
              <span><%= command[:label] %></span>
            </span>
            <span class="text-[0.6rem] text-phosphor-faint"><%= command[:hint] %></span>
          </button>
        </li>
      <% end %>
      <li class="hidden px-4 py-6 text-center text-phosphor-faint" data-command-palette-target="empty">
        &gt; no matches :: widen query _
      </li>
    </ul>
  </div>
</div>
