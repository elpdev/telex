<% nav_items = product_area_navigation_items %>
<% compact = local_assigns.fetch(:compact, false) %>
<% current_area = current_product_area %>
<% if compact %>
  <button type="button"
          class="group flex h-9 w-9 items-center justify-center border border-transparent hover:border-phosphor transition-colors"
          data-action="click->flyout#toggleApp"
          title="Modules">
    <%= image_tag "logo.webp", alt: "Telex", class: "h-7 w-auto select-none", draggable: "false" %>
  </button>
  <div data-flyout-target="appPanel"
       class="absolute left-14 top-0 z-40 hidden w-44 flex-col border border-hairline bg-bg-2 text-phosphor shadow-[0_0_30px_rgba(0,0,0,0.6)] glow-box-phosphor">
    <div class="flex items-center justify-between border-b border-hairline px-3 py-2 font-mono text-[0.6rem] uppercase tracking-widest">
      <span class="text-phosphor glow-phosphor">[ MODULES ]</span>
      <button type="button" data-action="flyout#close" class="text-phosphor-dim hover:text-amber">[ X ]</button>
    </div>
    <div class="grid grid-cols-2 gap-1 p-2">
      <% nav_items.each do |item| %>
        <% active = current_area == item[:key] %>
        <%= link_to item[:href],
            class: token_list(
              "flex h-14 flex-col items-center justify-center gap-1 border font-mono text-[0.55rem] uppercase tracking-wider transition-colors",
              active ? "border-amber bg-amber/10 text-amber glow-amber" : "border-hairline text-phosphor-dim hover:border-phosphor hover:text-phosphor"
            ),
            title: "#{item[:label]} :: #{item[:shortcut]}" do %>
          <span class="text-[0.7rem]"><%= item[:glyph] %></span>
          <span class="text-[0.5rem] tracking-[0.2em]"><%= item[:label].upcase %></span>
        <% end %>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="flex flex-wrap gap-2">
    <% nav_items.each do |item| %>
      <% active = current_area == item[:key] %>
      <%= link_to item[:href],
          class: token_list(
            "border px-3 py-1 font-mono text-[0.65rem] uppercase tracking-widest",
            active ? "border-amber text-amber glow-amber" : "border-hairline text-phosphor-dim hover:border-phosphor hover:text-phosphor"
          ),
          title: "#{item[:label]} :: #{item[:shortcut]}",
          data: {shortcut: item[:shortcut].delete(" ")} do %>
        [ <%= item[:label].upcase %> ]
      <% end %>
    <% end %>
  </div>
<% end %>
