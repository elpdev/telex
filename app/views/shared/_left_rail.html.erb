<%#
  Left rail :: 56px vertical icon nav.
  Icons are mono glyphs wrapped in brackets; active state is amber.
  Each link keeps a data-shortcut attr for the keyboard controller.
%>
<% current = (mailbox || "inbox").to_s %>
<% unread_count = (mailbox_counts && mailbox_counts["inbox"].to_i) || 0 %>
<% junk_count = (mailbox_counts && mailbox_counts["junk"].to_i) || 0 %>
<% archived_count = (mailbox_counts && mailbox_counts["archived"].to_i) || 0 %>
<% trash_count = (mailbox_counts && mailbox_counts["trash"].to_i) || 0 %>
<% sent_count = (mailbox_counts && mailbox_counts["sent"].to_i) || 0 %>
<% drafts_count = (drafts&.size || 0) %>
<nav class="flex h-full w-14 flex-col items-center justify-between border-r border-hairline bg-bg-2 py-3 text-phosphor"
     aria-label="Primary navigation"
     data-flyout-rail>
  <div class="flex flex-col items-center gap-1">
    <%= render "shared/app_switcher", compact: true %>
    <div class="my-2 h-px w-7 bg-hairline"></div>
    <%# Mailbox views %>
    <% rail_items = [
      {key: "inbox",    glyph: "INB", label: "Inbox",    shortcut: "g i", count: unread_count},
      {key: "junk",     glyph: "JNK", label: "Junk",     shortcut: "g j", count: junk_count},
      {key: "sent",     glyph: "OUT", label: "Sent",     shortcut: "g s", count: sent_count},
      {key: "drafts",   glyph: "DFT", label: "Drafts",   shortcut: "g d", count: drafts_count},
      {key: "archived", glyph: "ARC", label: "Archived", shortcut: "g a", count: archived_count},
      {key: "trash",    glyph: "TRH", label: "Trash",    shortcut: "g t", count: trash_count}
    ] %>
    <% rail_items.each do |item| %>
      <% is_current = current == item[:key] %>
      <% scoped_to_inbox = !%w[sent drafts].include?(item[:key]) %>
      <% href = item[:href] || root_path(inbox_browser_params({mailbox: item[:key], inbox_id: (scoped_to_inbox ? selected_inbox&.id : nil)}, except: [:message_id, :sent_message_id, :outbound_message_id, :page])) %>
      <%= link_to href,
          class: token_list(
            "group relative flex h-9 w-9 items-center justify-center border font-mono text-[0.62rem] uppercase tracking-wider transition-colors",
            is_current ? "border-amber bg-amber/10 text-amber glow-amber" : "border-transparent text-phosphor-dim hover:border-phosphor hover:text-phosphor"
          ),
          title: "#{item[:label]} :: #{item[:shortcut]}",
          data: {shortcut: item[:shortcut].tr(" ", "")} do %>
        <%= item[:glyph] %>
        <% if item[:count] && item[:count] > 0 && !is_current %>
          <span class="absolute -right-1 -top-1 min-w-[14px] border border-amber bg-bg px-0.5 text-[0.55rem] leading-none text-amber">
            <%= item[:count] > 99 ? "99+" : item[:count] %>
          </span>
        <% end %>
      <% end %>
    <% end %>
    <div class="my-2 h-px w-7 bg-hairline"></div>
    <%# Flyout: mailboxes (email addresses like hello@) %>
    <button type="button"
            class="group flex h-9 w-9 items-center justify-center border border-transparent font-mono text-[0.62rem] uppercase tracking-wider text-phosphor-dim hover:border-phosphor hover:text-phosphor"
            title="Mailboxes :: g m"
            data-action="click->flyout#toggleMbx"
      data-shortcut="gm">
      MBX
    </button>
    <%# Flyout: labels %>
    <button type="button"
            class="group flex h-9 w-9 items-center justify-center border border-transparent font-mono text-[0.62rem] uppercase tracking-wider text-phosphor-dim hover:border-phosphor hover:text-phosphor"
            title="Labels :: g l"
            data-action="click->flyout#toggleLbl"
      data-shortcut="gl">
      LBL
    </button>
  </div>
  <%# Bottom cluster: compose, help, account %>
  <div class="flex flex-col items-center gap-1">
    <%= button_to outbound_messages_path, params: {inbox_id: selected_inbox&.id, message_id: params[:message_id]},
        class: "group flex h-9 w-9 items-center justify-center border border-phosphor bg-phosphor/5 font-mono text-[0.62rem] uppercase tracking-wider text-phosphor hover:border-amber hover:text-amber hover:glow-amber",
        title: "Compose :: c",
        data: {shortcut: "c"},
        form_class: "m-0" do %>
      NEW
    <% end %>
    <div class="my-1 h-px w-7 bg-hairline"></div>
    <button type="button"
            class="flex h-9 w-9 items-center justify-center border border-transparent font-mono text-[0.62rem] uppercase tracking-wider text-phosphor-dim hover:border-phosphor hover:text-phosphor"
            title="Shortcuts :: ?"
            onclick="document.querySelector('[data-shortcut-help]').showModal()">
      ?
    </button>
    <%= link_to profile_path,
        class: "flex h-9 w-9 items-center justify-center border border-transparent font-mono text-[0.62rem] uppercase tracking-wider text-phosphor-dim hover:border-phosphor hover:text-phosphor",
        title: "Account" do %>
      @
    <% end %>
  </div>
</nav>
