<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Telex" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Telex">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="color-scheme" content="dark">
    <meta name="theme-color" content="#0B1220">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96">
    <link rel="shortcut icon" href="/favicon/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png">
    <meta name="apple-mobile-web-app-title" content="Telex">
    <link rel="manifest" href="/favicon/site.webmanifest">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Departure+Mono&family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <meta name="turbo-refresh-method" content="morph">
    <meta name="turbo-refresh-scroll" content="preserve">
    <%= stylesheet_link_tag "lexxy" %>
  </head>
  <body class="scanlines min-h-screen bg-bg text-phosphor font-mono antialiased">
    <%= render 'alerts' %>
    <% if content_for?(:app_shell) %>
      <div class="flex h-[100vh] w-full flex-col overflow-hidden bg-bg text-phosphor"
           data-controller="keyboard flyout"
           data-keyboard-product-value="<%= current_product_area %>">
        <div class="relative grid min-h-0 flex-1 grid-cols-1 <%= content_for?(:app_shell_grid) ? yield(:app_shell_grid) : 'xl:grid-cols-[3.5rem_minmax(0,1fr)]' %>">
          <div class="hidden xl:block">
            <%= yield :left_rail %>
          </div>
          <%= yield :flyout_panels %>
          <%= yield %>
        </div>
        <%= render "shared/status_bar" %>
        <%= render "shared/shortcut_help" %>
      </div>
    <% else %>
      <main class="<%= content_for?(:main_class) ? yield(:main_class) : 'mx-auto w-full max-w-6xl px-6 py-16' %>">
        <%= yield %>
      </main>
    <% end %>
    <% if authenticated? %>
      <div data-controller="command-palette"
           data-command-palette-tree-value="<%= json_escape(command_palette_commands.to_json) %>"
           data-command-palette-search-template-value="<%= command_palette_search_href %>">
        <%= render "shared/command_palette" %>
      </div>
    <% end %>
  </body>
</html>
