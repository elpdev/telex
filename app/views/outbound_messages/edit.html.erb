<% forward_draft = @outbound_message.metadata["draft_kind"] == "forward" %>
<% content_for :title, forward_draft ? "Forward" : "Reply" %>
<% selected_attachment = @outbound_message.attachments.find { |attachment| attachment.id == params[:outbound_attachment_id].to_i } if @outbound_message.attachments.attached? %>
<div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-8">
  <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400"><%= forward_draft ? "Outbound forward" : "Outbound reply" %></p>
      <h1 class="mt-2 text-3xl font-semibold text-gray-900 dark:text-white"><%= @outbound_message.subject.presence || (forward_draft ? "Forward" : "Reply") %></h1>
      <% if @outbound_message.source_message.present? %>
        <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
          <%= forward_draft ? "Forwarding" : "Replying to" %>
          <%= link_to @outbound_message.source_message.subject.presence || "(no subject)", root_path(inbox_id: @outbound_message.source_message.inbox_id, message_id: @outbound_message.source_message.id), class: "font-medium text-blue-600 hover:text-blue-500 dark:text-blue-400 dark:hover:text-blue-300" %>
          in <span class="font-medium"><%= @outbound_message.source_message.inbox.address %></span>
        </p>
      <% end %>
    </div>
    <%= link_to "Back to inbox", @outbound_message.source_message.present? ? root_path(inbox_id: @outbound_message.source_message.inbox_id, message_id: @outbound_message.source_message.id) : root_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white" %>
  </div>
  <% if @outbound_message.conversation.present? %>
    <div class="mb-6 rounded-3xl border border-gray-200 bg-gray-50/80 p-5 dark:border-gray-700 dark:bg-gray-900/50">
      <h2 class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">Thread history</h2>
      <div class="mt-3 space-y-3">
        <% @outbound_message.conversation.timeline_entries.each do |entry| %>
          <div class="rounded-2xl border border-gray-200 bg-white px-4 py-4 dark:border-gray-700 dark:bg-gray-800">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 dark:text-gray-400"><%= entry[:kind] == :inbound ? 'Inbound' : 'Outbound' %></p>
                <p class="mt-1 text-sm font-medium text-gray-900 dark:text-white"><%= entry[:sender] %></p>
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400"><%= l(entry[:occurred_at], format: :long) %></p>
            </div>
            <p class="mt-3 text-sm text-gray-700 dark:text-gray-200"><%= truncate(entry[:summary], length: 180) %></p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
  <div class="rounded-3xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
    <%= form_with model: @outbound_message, local: true, class: "space-y-6 p-6" do |form| %>
      <% if @outbound_message.errors.any? %>
        <div class="rounded-2xl border border-red-200 bg-red-50 px-4 py-4 text-sm text-red-700 dark:border-red-900 dark:bg-red-950/40 dark:text-red-200">
          <p class="font-semibold"><%= pluralize(@outbound_message.errors.count, "error") %> prevented this message from being saved:</p>
          <ul class="mt-2 list-disc pl-5">
            <% @outbound_message.errors.full_messages.each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        </div>
      <% end %>
      <div class="grid gap-6 md:grid-cols-2">
        <div class="md:col-span-2">
          <%= form.label :to_addresses, "To", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= text_area_tag "outbound_message[to_addresses]", @outbound_message.to_addresses.join(", "), rows: 2, class: "mt-2 w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 focus:border-blue-500 focus:outline-none dark:border-gray-600 dark:bg-gray-900 dark:text-white" %>
        </div>
        <div>
          <%= form.label :cc_addresses, "Cc", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= text_area_tag "outbound_message[cc_addresses]", @outbound_message.cc_addresses.join(", "), rows: 2, class: "mt-2 w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 focus:border-blue-500 focus:outline-none dark:border-gray-600 dark:bg-gray-900 dark:text-white" %>
        </div>
        <div>
          <%= form.label :bcc_addresses, "Bcc", class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= text_area_tag "outbound_message[bcc_addresses]", @outbound_message.bcc_addresses.join(", "), rows: 2, class: "mt-2 w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 focus:border-blue-500 focus:outline-none dark:border-gray-600 dark:bg-gray-900 dark:text-white" %>
        </div>
        <div class="md:col-span-2">
          <%= form.label :subject, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.text_field :subject, class: "mt-2 w-full rounded-2xl border border-gray-300 bg-white px-4 py-3 text-sm text-gray-900 focus:border-blue-500 focus:outline-none dark:border-gray-600 dark:bg-gray-900 dark:text-white" %>
        </div>
        <div class="md:col-span-2">
          <%= form.label :body, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <div class="mt-2 rounded-2xl border border-gray-300 bg-white px-3 py-3 dark:border-gray-600 dark:bg-gray-900">
            <%= form.rich_text_area :body, class: "min-h-64" %>
          </div>
        </div>
        <div class="md:col-span-2">
          <%= form.label :attachments, class: "block text-sm font-medium text-gray-700 dark:text-gray-300" %>
          <%= form.file_field :attachments, multiple: true, class: "mt-2 block w-full text-sm text-gray-700 dark:text-gray-300" %>
          <% if @outbound_message.attachments.attached? %>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <% @outbound_message.attachments.each do |attachment| %>
                <%= render "shared/attachment_card",
                    attachment: attachment,
                    selected: selected_attachment == attachment,
                    preview_select_path: attachment_previewable?(attachment) ? edit_outbound_message_path(@outbound_message, outbound_attachment_id: attachment.id) : nil,
                    download_path: download_outbound_message_attachment_path(@outbound_message, attachment) %>
              <% end %>
            </div>
            <% if selected_attachment.present? %>
              <%= render "shared/attachment_preview", attachment: selected_attachment, preview_url: outbound_message_attachment_path(@outbound_message, selected_attachment) %>
            <% end %>
          <% end %>
        </div>
      </div>
      <div class="flex flex-wrap items-center justify-end gap-3 border-t border-gray-200 pt-6 dark:border-gray-700">
        <%= form.submit "Save draft", class: "rounded-full border border-gray-300 px-5 py-2.5 text-sm font-medium text-gray-700 transition hover:border-gray-400 hover:text-gray-900 dark:border-gray-600 dark:text-gray-200 dark:hover:border-gray-500 dark:hover:text-white" %>
        <%= form.button forward_draft ? "Send forward" : "Send reply", name: :send_now, value: "1", class: "rounded-full bg-blue-600 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-blue-500" %>
      </div>
    <% end %>
  </div>
</div>
