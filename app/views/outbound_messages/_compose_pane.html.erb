<% kind = compose_kind(outbound_message) %>
<% send_ready = compose_send_ready?(outbound_message) %>
<% selected_attachment = outbound_message.attachments.find { |attachment| attachment.id == params[:outbound_attachment_id].to_i } if outbound_message.attachments.attached? %>
<% available_templates = outbound_message.domain.email_templates.alphabetical %>
<%#
  Compose pane :: terminal prompt form.
  Rendered inline at the bottom of the thread reader, or as a standalone
  pane when the user starts a fresh compose with no source message.
%>
<div class="flex flex-col bg-bg text-phosphor font-mono">
  <%# Header band %>
  <div class="border-b border-hairline bg-bg-2 px-5 py-3">
    <div class="flex items-start justify-between gap-4">
      <div class="min-w-0">
        <p class="text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">
          &gt; Compose ::
          <span class="text-amber">
            <% case kind
            when "forward" then %>Forward<% when "reply" then %>Reply<% else %>New message<% end %>
          </span>
          <% if outbound_message.source_message.present? %>
            <span class="text-phosphor-dim">::</span>
            <span class="text-phosphor"><%= truncate(outbound_message.source_message.subject.to_s, length: 48) %></span>
          <% end %>
        </p>
        <div class="mt-2 flex flex-wrap items-center gap-x-3 gap-y-1 text-[0.68rem] uppercase tracking-wider">
          <span class="text-phosphor-faint">From</span>
          <span class="text-phosphor"><%= compose_sender_identity(outbound_message) %></span>
          <span class="text-hairline">&middot;</span>
          <span class="text-cyan"><%= compose_sender_context(outbound_message) %></span>
          <% if compose_reply_to_hint(outbound_message).present? %>
            <span class="text-hairline">&middot;</span>
            <span class="text-phosphor-dim"><%= compose_reply_to_hint(outbound_message) %></span>
          <% end %>
        </div>
      </div>
      <%= link_to "[ X · close ]", root_path(inbox_browser_params({}, except: [:outbound_message_id])),
          class: "shrink-0 border border-hairline px-2 py-1 text-[0.65rem] uppercase tracking-wider text-phosphor-dim hover:border-signal hover:text-signal" %>
    </div>
  </div>

  <div class="flex-1">
    <%= form_with model: outbound_message, local: true, class: "space-y-4 px-5 py-4 text-sm",
                  data: {controller: "draft-autosave", draft_autosave_delay_value: 1200, draft_autosave_url_value: outbound_message_path(outbound_message)} do |form| %>
      <%= hidden_field_tag :inbox_id, params[:inbox_id] || selected_inbox&.id %>
      <%= hidden_field_tag :message_id, params[:message_id] || selected_message&.id %>
      <%= hidden_field_tag :autosave, "0", data: {draft_autosave_target: "autosaveField"} %>

      <% if outbound_message.errors.any? %>
        <div class="border border-signal bg-signal/10 px-3 py-2 text-xs text-signal">
          <p class="uppercase tracking-widest">&gt; <%= pluralize(outbound_message.errors.count, "error") %> blocked save</p>
          <ul class="mt-2 list-disc pl-4 text-phosphor">
            <% outbound_message.errors.full_messages.each do |error| %>
              <li><%= error %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <% if compose_send_warning(outbound_message).present? %>
        <div class="border border-amber bg-amber/5 px-3 py-2 text-xs">
          <p class="uppercase tracking-widest text-amber">&gt; Send unavailable</p>
          <p class="mt-1 text-phosphor"><%= compose_send_warning(outbound_message) %></p>
        </div>
      <% end %>

      <%# TO / CC / BCC :: terminal prompt rows %>
      <div class="flex items-start gap-3">
        <label class="w-12 shrink-0 pt-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">To</label>
        <%= text_area_tag "outbound_message[to_addresses]", outbound_message.to_addresses.join(", "), rows: 2,
            class: "w-full border border-hairline bg-bg px-3 py-2 font-mono text-xs text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
      </div>
      <div class="grid gap-3 md:grid-cols-2">
        <div class="flex items-start gap-3">
          <label class="w-12 shrink-0 pt-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Cc</label>
          <%= text_area_tag "outbound_message[cc_addresses]", outbound_message.cc_addresses.join(", "), rows: 2,
              class: "w-full border border-hairline bg-bg px-3 py-2 font-mono text-xs text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
        </div>
        <div class="flex items-start gap-3">
          <label class="w-12 shrink-0 pt-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Bcc</label>
          <%= text_area_tag "outbound_message[bcc_addresses]", outbound_message.bcc_addresses.join(", "), rows: 2,
              class: "w-full border border-hairline bg-bg px-3 py-2 font-mono text-xs text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
        </div>
      </div>
      <div class="flex items-start gap-3">
        <label class="w-12 shrink-0 pt-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Subj</label>
        <%= form.text_field :subject,
            class: "w-full border border-hairline bg-bg px-3 py-2 font-mono text-xs text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
      </div>
      <% if available_templates.any? %>
        <div class="flex items-start gap-3">
          <label class="w-12 shrink-0 pt-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Tmpl</label>
          <div class="w-full">
            <%= select_tag :insert_template_id,
                options_for_select([["-- insert template --", ""]] + available_templates.map { |t| [t.name, t.id] }),
                onchange: "this.form.requestSubmit()",
                class: "w-full border border-hairline bg-bg px-3 py-2 font-mono text-xs text-phosphor focus:border-phosphor focus:outline-none" %>
            <p class="mt-1 text-[0.6rem] uppercase tracking-widest text-phosphor-faint">&gt; pick to prepend into the body :: subject auto-fills when blank</p>
          </div>
        </div>
      <% end %>

      <div class="flex items-start gap-3">
        <label class="w-12 shrink-0 pt-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Body</label>
        <div class="w-full border border-hairline bg-bg px-3 py-2">
          <%= form.rich_text_area :body, class: "min-h-48 text-phosphor" %>
        </div>
      </div>

      <%# Attachments %>
      <div class="flex items-start gap-3">
        <label class="w-12 shrink-0 pt-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Files</label>
        <div class="w-full">
          <%= form.file_field :attachments, multiple: true, class: "block w-full text-xs text-phosphor file:mr-3 file:border file:border-hairline file:bg-bg-2 file:px-2 file:py-1 file:font-mono file:text-[0.65rem] file:uppercase file:tracking-wider file:text-phosphor hover:file:border-phosphor" %>
          <% if outbound_message.attachments.attached? %>
            <div class="mt-3 grid gap-2 sm:grid-cols-2">
              <% outbound_message.attachments.each do |attachment| %>
                <%= render "shared/attachment_card",
                    attachment: attachment,
                    selected: selected_attachment == attachment,
                    preview_select_path: attachment_previewable?(attachment) ? root_path(inbox_browser_params({outbound_attachment_id: attachment.id}, except: [:attachment_id, :sent_attachment_id])) : nil,
                    download_path: download_outbound_message_attachment_path(outbound_message, attachment) %>
              <% end %>
            </div>
            <% if selected_attachment.present? %>
              <%= render "shared/attachment_preview", attachment: selected_attachment, preview_url: outbound_message_attachment_path(outbound_message, selected_attachment) %>
            <% end %>
          <% end %>
        </div>
      </div>

      <%# Submit row :: terminal prompt %>
      <div class="flex flex-wrap items-center justify-between gap-3 border-t border-hairline pt-4">
        <p class="text-[0.65rem] uppercase tracking-widest text-phosphor-dim" data-draft-autosave-target="status">
          &gt; autosaved<span class="blink text-amber">_</span>
        </p>
        <div class="flex flex-wrap items-center gap-2">
          <%= form.submit "[ Save draft ]",
              class: "cursor-pointer border border-hairline bg-bg-2 px-3 py-1.5 font-mono text-[0.65rem] uppercase tracking-widest text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
          <% send_label = case kind
             when "forward" then "[ Send forward ]"
             when "reply" then "[ Send reply ]"
             else "[ Send message ]"
             end %>
          <%= form.button send_label, name: :send_now, value: "1", disabled: !send_ready,
              class: "cursor-pointer border font-mono text-[0.65rem] uppercase tracking-widest px-3 py-1.5 #{send_ready ? 'border-amber bg-amber/10 text-amber hover:glow-amber' : 'border-hairline text-phosphor-faint cursor-not-allowed'}" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
