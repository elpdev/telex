<% content_for :title, "Telex // new api key" %>
<% content_for :main_class, "m-0 p-0 w-full min-h-screen bg-bg" %>

<%= render "shared/settings_shell", active: :api_keys, title: "New API Key" do %>
  <%= render Frame::Component.new(title: "Provision credential", variant: :hairline, padding: :lg) do %>
    <%= form_with model: @api_key, local: true, class: "space-y-5 font-mono" do |form| %>
      <% if @api_key.errors.any? %>
        <div class="border border-signal bg-signal/10 px-3 py-2 text-[0.65rem] uppercase tracking-widest text-signal">
          &gt; <%= pluralize(@api_key.errors.count, "error") %> blocked creation
          <ul class="mt-2 list-disc pl-4 text-phosphor">
            <% @api_key.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Label</label>
        <%= form.text_field :name, placeholder: "e.g. agent-prod-01",
            class: "mt-2 block w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
        <p class="mt-1 text-[0.6rem] uppercase tracking-widest text-phosphor-faint">&gt; a descriptive identifier for this key</p>
      </div>

      <div>
        <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Expires (optional)</label>
        <%= form.datetime_local_field :expires_at,
            class: "mt-2 block w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor focus:border-phosphor focus:outline-none" %>
        <p class="mt-1 text-[0.6rem] uppercase tracking-widest text-phosphor-faint">&gt; leave blank for no expiration</p>
      </div>

      <div class="flex flex-wrap items-center gap-3 border-t border-hairline pt-5">
        <%= form.submit "[ > CREATE KEY ]",
            class: "cursor-pointer border border-amber bg-amber/5 px-4 py-2 text-[0.7rem] uppercase tracking-widest text-amber hover:glow-amber" %>
        <%= link_to "[ CANCEL ]", api_keys_path,
            class: "border border-hairline px-4 py-2 text-[0.7rem] uppercase tracking-widest text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
      </div>
    <% end %>
  <% end %>
<% end %>
