<div class="flex items-start justify-between gap-4 px-5 py-4 font-mono">
  <div class="min-w-0 flex-1">
    <div class="flex flex-wrap items-center gap-2">
      <span class="text-sm text-phosphor"><%= api_key.name %></span>
      <% if api_key.expired? %>
        <%= phosphor_badge("expired", variant: :signal) %>
      <% else %>
        <%= phosphor_badge("active", variant: :moss) %>
      <% end %>
    </div>
    <div class="mt-1 text-xs text-cyan" data-controller="copy" data-copy-value="<%= api_key.client_id %>">
      <span class="text-phosphor-dim">client_id::</span>
      <span><%= api_key.client_id %></span>
    </div>
    <div class="mt-2 flex flex-wrap gap-x-6 gap-y-1 text-[0.65rem] uppercase tracking-widest text-phosphor-faint">
      <span>created <%= time_ago_in_words(api_key.created_at) %> ago</span>
      <% if api_key.last_used_at %>
        <span>last used <%= time_ago_in_words(api_key.last_used_at) %> ago<%= " :: #{api_key.last_used_ip}" if api_key.last_used_ip %></span>
      <% else %>
        <span>never used</span>
      <% end %>
      <% if api_key.expires_at %>
        <span>expires <%= api_key.expires_at.strftime("%Y-%m-%d") %></span>
      <% end %>
    </div>
  </div>
  <%= button_to "[ REVOKE ]", api_key_path(api_key), method: :delete,
      data: { turbo_confirm: "Revoke this API key? Cannot be undone." },
      class: "shrink-0 border border-signal px-3 py-1 text-[0.65rem] uppercase tracking-widest text-signal hover:bg-signal hover:text-bg",
      form_class: "inline" %>
</div>
