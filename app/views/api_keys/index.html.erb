<% content_for :title, "Telex // api credentials" %>
<% content_for :main_class, "m-0 p-0 w-full min-h-screen bg-bg" %>

<%= render "shared/settings_shell", active: :api_keys, title: "API Credentials" do %>
  <% if flash[:api_secret].present? %>
    <div class="mb-6 border border-amber bg-amber/5 p-5 font-mono">
      <div class="flex items-center justify-between gap-3">
        <p class="text-[0.65rem] uppercase tracking-widest text-amber">
          [ SECRET :: RECORD NOW, NOT DISPLAYED AGAIN ]
        </p>
        <span class="blink text-amber">_</span>
      </div>
      <div class="mt-3 flex flex-wrap items-center gap-3">
        <code class="flex-1 break-all border border-amber/50 bg-bg px-3 py-2 text-sm text-amber glow-amber">
          <%= flash[:api_secret] %>
        </code>
        <button onclick="navigator.clipboard.writeText('<%= flash[:api_secret] %>')"
                class="border border-amber px-3 py-2 text-[0.65rem] uppercase tracking-widest text-amber hover:glow-amber">
          [ COPY ]
        </button>
      </div>
    </div>
  <% end %>

  <div class="mb-4 flex items-center justify-between">
    <p class="font-mono text-[0.65rem] uppercase tracking-widest text-phosphor-dim">
      &gt; <%= @api_keys.size %> credential(s) provisioned
    </p>
    <%= link_to "[ + NEW KEY ]", new_api_key_path,
        class: "border border-amber bg-amber/5 px-3 py-1.5 font-mono text-[0.65rem] uppercase tracking-widest text-amber hover:glow-amber" %>
  </div>

  <%= render Frame::Component.new(title: "Keys", variant: :hairline, padding: :none) do %>
    <% if @api_keys.any? %>
      <div class="divide-y divide-hairline">
        <%= render @api_keys %>
      </div>
    <% else %>
      <div class="px-6 py-10 text-center font-mono text-xs text-phosphor-dim">
        &gt; no credentials provisioned :: create one to connect agents<span class="blink text-amber">_</span>
      </div>
    <% end %>
  <% end %>

  <div class="mt-8 space-y-4">
    <h2 class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">// api usage</h2>
    <div class="border border-hairline bg-bg-2">
      <div class="border-b border-hairline px-4 py-2 font-mono text-[0.6rem] uppercase tracking-widest text-phosphor-dim">
        [ 01 :: EXCHANGE CREDENTIALS FOR JWT ]
      </div>
      <pre class="overflow-x-auto px-4 py-3 font-mono text-xs leading-relaxed text-phosphor"><code>$ curl -X POST <%= request.base_url %>/api/v1/auth/token \
    -H "Content-Type: application/json" \
    -d '{"client_id": "your_client_id", "secret_key": "your_secret_key"}'</code></pre>
    </div>
    <div class="border border-hairline bg-bg-2">
      <div class="border-b border-hairline px-4 py-2 font-mono text-[0.6rem] uppercase tracking-widest text-phosphor-dim">
        [ 02 :: AUTHENTICATE REQUESTS ]
      </div>
      <pre class="overflow-x-auto px-4 py-3 font-mono text-xs leading-relaxed text-phosphor"><code>$ curl <%= request.base_url %>/api/v1/messages \
    -H "Authorization: Bearer your_jwt_token"</code></pre>
    </div>
  </div>
<% end %>
