<% if notice %>
  <div class="fixed right-6 top-6 z-[10000] border border-moss bg-bg-2 px-4 py-3 font-mono text-xs uppercase tracking-widest text-moss shadow-[0_0_18px_rgba(79,174,122,0.25)]" role="alert">
    <div class="flex items-center gap-3">
      <span class="text-moss">[OK]</span>
      <span class="text-phosphor"><%= notice %></span>
      <button type="button" class="ml-4 text-phosphor-dim hover:text-amber" onclick="this.parentElement.parentElement.remove()">[x]</button>
    </div>
  </div>
<% end %>
<% if alert %>
  <div class="fixed right-6 top-6 z-[10000] border border-signal bg-bg-2 px-4 py-3 font-mono text-xs uppercase tracking-widest text-signal shadow-[0_0_18px_rgba(255,94,91,0.3)]" role="alert">
    <div class="flex items-center gap-3">
      <span class="text-signal">[ERR]</span>
      <span class="text-phosphor"><%= alert %></span>
      <button type="button" class="ml-4 text-phosphor-dim hover:text-amber" onclick="this.parentElement.parentElement.remove()">[x]</button>
    </div>
  </div>
<% end %>
