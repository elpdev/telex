<%= link_to notifications_path, class: "relative text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200" do %>
  <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
  </svg>
  <% unread_count = Current.user.notifications.unread.count %>
  <% if unread_count > 0 %>
    <span class="absolute -top-1 -right-1 inline-flex items-center justify-center h-4 min-w-4 px-1 rounded-full text-[10px] font-bold text-white bg-red-500">
      <%= unread_count > 99 ? "99+" : unread_count %>
    </span>
  <% end %>
<% end %>
