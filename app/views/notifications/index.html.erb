<div class="mx-auto max-w-3xl">
  <div class="flex items-center justify-between mb-6">
    <h1 class="font-bold text-3xl text-gray-900 dark:text-white">Notifications</h1>
    <% if Current.user.notifications.unread.any? %>
      <%= button_to "Mark all as read", mark_all_read_notifications_path, method: :post,
          class: "text-sm text-blue-600 dark:text-blue-400 hover:text-blue-800 dark:hover:text-blue-300 cursor-pointer" %>
    <% end %>
  </div>

  <% if @notifications.any? %>
    <div class="space-y-2">
      <% @notifications.each do |notification| %>
        <div class="flex items-start gap-3 p-4 rounded-lg border <%= notification.read? ? 'bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700' : 'bg-blue-50 dark:bg-blue-900/20 border-blue-200 dark:border-blue-800' %>">
          <% unless notification.read? %>
            <span class="mt-1.5 h-2 w-2 rounded-full bg-blue-500 shrink-0"></span>
          <% end %>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-gray-900 dark:text-white"><%= notification.message %></p>
            <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= time_ago_in_words(notification.created_at) %> ago</p>
          </div>
          <% unless notification.read? %>
            <%= button_to "Read", notification_path(notification), method: :patch,
                class: "text-xs text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 cursor-pointer" %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0" />
      </svg>
      <p class="mt-2 text-sm text-gray-500 dark:text-gray-400">No notifications yet.</p>
    </div>
  <% end %>
</div>
