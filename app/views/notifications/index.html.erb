<% content_for :title, "Telex // notifications" %>
<% content_for :main_class, "m-0 p-0 w-full min-h-screen bg-bg" %>

<%= render "shared/settings_shell", active: :notifications, title: "Notifications" do %>
  <div class="mb-4 flex items-center justify-between">
    <p class="font-mono text-[0.65rem] uppercase tracking-widest text-phosphor-dim">
      &gt; activity log :: <%= Current.user.notifications.unread.count %> unread
    </p>
    <% if Current.user.notifications.unread.any? %>
      <%= button_to "[ MARK ALL READ ]", mark_all_read_notifications_path, method: :post,
          class: "border border-phosphor px-3 py-1.5 font-mono text-[0.65rem] uppercase tracking-widest text-phosphor hover:border-amber hover:text-amber",
          form_class: "inline" %>
    <% end %>
  </div>

  <%= render Frame::Component.new(title: "Event feed", variant: :hairline, padding: :none) do %>
    <% if @notifications.any? %>
      <div class="divide-y divide-hairline">
        <% @notifications.each_with_index do |notification, i| %>
          <div class="flex items-start gap-4 px-5 py-3 font-mono text-sm <%= notification.read? ? '' : 'bg-amber/5' %>">
            <span class="shrink-0 pt-1 text-[0.62rem] text-phosphor-faint tabular-nums">
              <%= row_number(i + 1) %>
            </span>
            <span class="shrink-0 pt-1">
              <% if notification.read? %>
                <span class="text-phosphor-faint">&middot;</span>
              <% else %>
                <span class="inline-block h-1.5 w-1.5 bg-amber"></span>
              <% end %>
            </span>
            <div class="min-w-0 flex-1">
              <p class="text-phosphor"><%= notification.message %></p>
              <p class="mt-1 text-[0.6rem] uppercase tracking-widest text-phosphor-faint">
                <%= time_ago_in_words(notification.created_at) %> ago
              </p>
            </div>
            <% unless notification.read? %>
              <%= button_to "[ ACK ]", notification_path(notification), method: :patch,
                  class: "shrink-0 border border-hairline px-2 py-0.5 text-[0.6rem] uppercase tracking-widest text-phosphor-dim hover:border-phosphor hover:text-phosphor",
                  form_class: "inline" %>
            <% end %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="px-6 py-12 text-center font-mono text-xs text-phosphor-dim">
        &gt; no events logged :: system quiet<span class="blink text-amber">_</span>
      </div>
    <% end %>
  <% end %>
<% end %>
