<%= form_with model: [domain, inbox], local: true, class: "space-y-5 font-mono" do |form| %>
  <% if inbox.errors.any? %>
    <div class="border border-signal bg-signal/10 px-3 py-2 text-[0.65rem] uppercase tracking-widest text-signal">
      &gt; <%= pluralize(inbox.errors.count, "error") %> blocked save
      <ul class="mt-2 list-disc pl-4 text-phosphor">
        <% inbox.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
  <div class="border border-hairline bg-bg-2 px-4 py-3 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">
    &gt; domain :: <span class="text-phosphor"><%= domain.name %></span>
  </div>
  <div class="grid gap-5 lg:grid-cols-2">
    <div>
      <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Local part</label>
      <div class="mt-2 flex items-center border border-hairline bg-bg text-sm text-phosphor focus-within:border-phosphor">
        <%= form.text_field :local_part, placeholder: "support",
            class: "w-full border-0 bg-transparent px-3 py-2 text-phosphor placeholder:text-phosphor-faint focus:outline-none" %>
        <span class="border-l border-hairline px-3 py-2 text-phosphor-dim">@<%= domain.name %></span>
      </div>
    </div>
    <div>
      <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Pipeline</label>
      <%= form.select :pipeline_key,
          options_for_select(Inbound::PipelineRegistry.keys.map { |key| [key, key] }, inbox.pipeline_key),
          {},
          class: "mt-2 block w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor focus:border-phosphor focus:outline-none" %>
    </div>
    <div class="lg:col-span-2">
      <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Description</label>
      <%= form.text_area :description, rows: 3, placeholder: "Optional routing notes for operators",
          class: "mt-2 block w-full border border-hairline bg-bg px-3 py-2 text-sm text-phosphor placeholder:text-phosphor-faint focus:border-phosphor focus:outline-none" %>
    </div>
    <div class="lg:col-span-2">
      <label class="inline-flex items-center gap-2 text-[0.65rem] uppercase tracking-widest text-phosphor-dim">
        <%= form.check_box :active, class: "border border-hairline bg-bg" %>
        <span>Inbox active</span>
      </label>
    </div>
  </div>
  <div class="border-t border-hairline pt-5">
    <p class="text-[0.65rem] uppercase tracking-[0.3em] text-phosphor-dim">// advanced routing json</p>
  </div>
  <div>
    <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Notification recipient</label>
    <% selected_notify_user_id = inbox.pipeline_overrides["notify_user_id"]&.to_s %>
    <div class="mt-2 space-y-2 border border-hairline bg-bg-2 p-3">
      <label class="flex items-center justify-between gap-3 border border-hairline px-3 py-2 text-sm text-phosphor hover:border-phosphor">
        <span>
          <span class="block uppercase tracking-widest text-phosphor">Default admin routing</span>
          <span class="mt-1 block text-[0.65rem] uppercase tracking-widest text-phosphor-faint">Uses the system default admin recipient for this pipeline</span>
        </span>
        <%= radio_button_tag "inbox[notify_user_id]", "", selected_notify_user_id.blank?, class: "border border-hairline bg-bg" %>
      </label>
      <% @notification_recipients.each do |user| %>
        <% checked = selected_notify_user_id == user.id.to_s %>
        <label class="flex items-center justify-between gap-3 border border-hairline px-3 py-2 text-sm text-phosphor hover:border-phosphor">
          <span>
            <span class="block uppercase tracking-widest text-phosphor"><%= user.email_address %></span>
            <span class="mt-1 block text-[0.65rem] uppercase tracking-widest text-phosphor-faint"><%= user.admin? ? "ADMIN" : "USER" %></span>
          </span>
          <%= radio_button_tag "inbox[notify_user_id]", user.id, checked, class: "border border-hairline bg-bg" %>
        </label>
      <% end %>
    </div>
    <p class="mt-1 text-[0.6rem] uppercase tracking-widest text-phosphor-faint">&gt; choose who should receive inbox notifications for this pipeline</p>
  </div>
  <div>
    <label class="block text-[0.65rem] uppercase tracking-widest text-phosphor-dim">Forwarding rules</label>
    <%= form.text_area :forwarding_rules,
        value: JSON.pretty_generate(inbox.forwarding_rules), rows: 12, spellcheck: false,
        class: "mt-2 block w-full border border-hairline bg-bg px-3 py-2 font-mono text-sm text-phosphor focus:border-phosphor focus:outline-none" %>
    <p class="mt-1 text-[0.6rem] uppercase tracking-widest text-phosphor-faint">&gt; enter a json array or leave blank for []</p>
  </div>
  <div class="flex flex-wrap items-center gap-3 border-t border-hairline pt-5">
    <%= form.submit "[ > SAVE INBOX ]",
        class: "cursor-pointer border border-amber bg-amber/5 px-4 py-2 text-[0.7rem] uppercase tracking-widest text-amber hover:glow-amber" %>
    <%= link_to "[ CANCEL ]", domain_path(domain),
        class: "border border-hairline px-4 py-2 text-[0.7rem] uppercase tracking-widest text-phosphor-dim hover:border-phosphor hover:text-phosphor" %>
  </div>
<% end %>
