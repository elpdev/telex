<%#
  Message list :: feed column.
  Renders the filter chip bar, numbered rows, and pagy footer.
%>
<div class="flex h-full flex-col overflow-hidden bg-bg">
  <%# Header: scope + count %>
  <div class="flex items-center justify-between border-b border-hairline px-5 py-3">
    <div class="flex items-center gap-3 font-mono text-[0.7rem] uppercase tracking-widest">
      <span class="text-phosphor-dim">&gt;</span>
      <span class="text-phosphor glow-phosphor">
        [<%= (mailbox || "inbox").upcase %>]
      </span>
      <% if selected_inbox.present? %>
        <span class="text-hairline">::</span>
        <span class="text-cyan"><%= selected_inbox.address %></span>
      <% elsif @selected_domain.present? %>
        <span class="text-hairline">::</span>
        <span class="text-cyan">//<%= @selected_domain.name %></span>
      <% end %>
      <span class="blink text-amber">_</span>
    </div>
    <span class="font-mono text-[0.62rem] uppercase tracking-widest text-phosphor-faint">
      <%= pagy.count %> TOTAL :: PAGE <%= pagy.page %>/<%= pagy.pages %>
    </span>
  </div>
  <%= render "inboxes/filter_chips",
      q: @q || {},
      mailbox: mailbox,
      selected_inbox: selected_inbox,
      selected_domain: @selected_domain,
      selected_label: selected_label,
      labels: labels,
      pagy: pagy %>
  <%# Feed rows %>
  <div class="flex-1 overflow-y-auto">
    <% if messages.any? %>
      <% messages.each_with_index do |entry, index| %>
        <% row_index = (pagy.offset || 0) + index + 1 %>
        <% if mailbox == "sent" %>
          <%= render "inboxes/sent_row", outbound_message: entry, selected: selected_sent_message&.id == entry.id, row_index: row_index %>
        <% elsif mailbox == "drafts" %>
          <%= render "inboxes/draft_row", outbound_message: entry, selected: @outbound_message&.id == entry.id, row_index: row_index %>
        <% else %>
          <%= render "inboxes/message_row", message: entry, selected: selected_message&.id == entry.id, row_index: row_index %>
        <% end %>
      <% end %>
    <% else %>
      <div class="flex h-full flex-col items-center justify-center px-8 py-16 text-center font-mono">
        <p class="text-xs uppercase tracking-[0.3em] text-phosphor-dim">&gt; empty</p>
        <p class="mt-4 text-sm text-phosphor">
          <% case (mailbox || "inbox") %>
          <% when "inbox" %>
            inbox empty :: all mailboxes quiet<span class="blink text-amber">_</span>
          <% when "archived" %>
            archive vault empty<span class="blink text-amber">_</span>
          <% when "trash" %>
            trash bin clear<span class="blink text-amber">_</span>
          <% when "sent" %>
            no transmissions logged<span class="blink text-amber">_</span>
          <% when "drafts" %>
            no drafts staged<span class="blink text-amber">_</span>
          <% else %>
            no entries<span class="blink text-amber">_</span>
          <% end %>
        </p>
        <% if @q.present? && @q.values.any?(&:present?) %>
          <p class="mt-3 text-[0.65rem] uppercase tracking-wider text-phosphor-faint">
            query returned zero :: widen scope
          </p>
        <% end %>
      </div>
    <% end %>
  </div>
  <%# Pagy footer %>
  <% if pagy.pages > 1 %>
    <% previous_page = pagy.page > 1 ? pagy.page - 1 : nil %>
    <% next_page = pagy.page < pagy.pages ? pagy.page + 1 : nil %>
    <div class="flex items-center justify-between border-t border-hairline px-4 py-2 font-mono text-[0.65rem] uppercase tracking-wider text-phosphor-dim">
      <div>
        page <%= pagy.page %> / <%= pagy.pages %>
      </div>
      <div class="flex items-center gap-2">
        <% if previous_page.present? %>
          <%= link_to "< prev", root_path(inbox_browser_params({page: previous_page}, except: [:message_id])), class: "border border-hairline px-2 py-0.5 text-phosphor hover:border-amber hover:text-amber" %>
        <% else %>
          <span class="border border-hairline px-2 py-0.5 text-phosphor-faint">&lt; prev</span>
        <% end %>
        <% if next_page.present? %>
          <%= link_to "next >", root_path(inbox_browser_params({page: next_page}, except: [:message_id])), class: "border border-hairline px-2 py-0.5 text-phosphor hover:border-amber hover:text-amber" %>
        <% else %>
          <span class="border border-hairline px-2 py-0.5 text-phosphor-faint">next &gt;</span>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
