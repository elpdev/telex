<% selected_attachment = outbound_message&.attachments&.find { |attachment| attachment.id == params[:sent_attachment_id].to_i } %>
<div class="flex h-full flex-col">
  <% if outbound_message.present? %>
    <div class="border-b border-gray-200 px-6 py-5 dark:border-gray-700">
      <div class="flex flex-col gap-4">
        <div class="flex flex-wrap items-start justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">Sent message</p>
            <h2 class="mt-2 text-2xl font-semibold text-gray-900 dark:text-white"><%= outbound_message.subject.presence || "(no subject)" %></h2>
          </div>
          <% if selected_conversation.present? %>
            <div class="flex flex-wrap items-center justify-end gap-2">
              <%= button_to "Archive thread", archive_conversation_path(selected_conversation), method: :post, class: "rounded-full border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition hover:border-blue-500 hover:text-blue-600 dark:border-gray-600 dark:text-gray-200" %>
              <%= button_to "Restore thread", restore_conversation_path(selected_conversation), method: :post, class: "rounded-full border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition hover:border-blue-500 hover:text-blue-600 dark:border-gray-600 dark:text-gray-200" %>
              <%= button_to "Trash thread", trash_conversation_path(selected_conversation), method: :post, class: "rounded-full bg-red-600 px-4 py-2 text-sm font-medium text-white transition hover:bg-red-500" %>
            </div>
          <% end %>
        </div>
        <dl class="grid gap-4 text-sm text-gray-600 dark:text-gray-300 sm:grid-cols-2">
          <div>
            <dt class="font-medium text-gray-900 dark:text-white">From</dt>
            <dd class="mt-1"><%= compose_sender_identity(outbound_message) %></dd>
          </div>
          <div>
            <dt class="font-medium text-gray-900 dark:text-white">Sent</dt>
            <dd class="mt-1"><%= l(outbound_message.sent_at || outbound_message.created_at, format: :long) %></dd>
          </div>
          <div class="sm:col-span-2">
            <dt class="font-medium text-gray-900 dark:text-white">To</dt>
            <dd class="mt-1 break-words"><%= recipient_list(outbound_message.to_addresses).presence || "No recipients" %></dd>
          </div>
        </dl>
      </div>
    </div>
    <div class="flex-1 overflow-y-auto px-6 py-6">
      <div class="rounded-3xl border border-gray-200 bg-gray-50/80 p-5 dark:border-gray-700 dark:bg-gray-900/60">
        <div class="lexxy text-sm text-gray-800 dark:text-gray-100">
          <%= outbound_message.body %>
        </div>
      </div>
      <% if outbound_message.attachments.attached? %>
        <div class="mt-6">
          <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">Attachments</h3>
          <div class="mt-3 grid gap-3 sm:grid-cols-2">
            <% outbound_message.attachments.each do |attachment| %>
              <%= render "shared/attachment_card",
                  attachment: attachment,
                  selected: selected_attachment == attachment,
                  preview_select_path: attachment_previewable?(attachment) ? root_path(inbox_browser_params({sent_attachment_id: attachment.id}, except: [:attachment_id, :outbound_attachment_id])) : nil,
                  download_path: download_outbound_message_attachment_path(outbound_message, attachment) %>
            <% end %>
          </div>
          <% if selected_attachment.present? %>
            <%= render "shared/attachment_preview", attachment: selected_attachment, preview_url: outbound_message_attachment_path(outbound_message, selected_attachment) %>
          <% end %>
        </div>
      <% end %>
      <% if selected_conversation.present? %>
        <div class="mt-6 rounded-2xl border border-gray-200 bg-gray-50/80 px-4 py-4 dark:border-gray-700 dark:bg-gray-900/50">
          <div class="flex items-center justify-between gap-3">
            <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">Thread labels</h3>
            <%= render Badge::Component.new(text: selected_conversation.effective_system_state_for(Current.user), variant: organization_state_variant(selected_conversation.effective_system_state_for(Current.user)), size: :small) %>
          </div>
          <%= form_with url: labels_conversation_path(selected_conversation), method: :patch, class: "mt-3 grid gap-2" do %>
            <% labels.each do |label| %>
              <label class="flex items-center gap-2 text-sm text-gray-700 dark:text-gray-300">
                <%= check_box_tag "label_ids[]", label.id, selected_conversation.labels_for(Current.user).any? { |assigned| assigned.id == label.id } %>
                <span><%= label.name %></span>
              </label>
            <% end %>
            <%= submit_tag "Save thread labels", class: "inline-flex cursor-pointer items-center rounded-2xl bg-gray-900 px-4 py-2 text-sm font-medium text-white transition hover:bg-gray-700 dark:bg-white dark:text-gray-900 dark:hover:bg-gray-200" %>
          <% end %>
        </div>
      <% end %>
      <% if thread_timeline.many? %>
        <div class="mt-6">
          <h3 class="text-sm font-semibold uppercase tracking-[0.18em] text-gray-500 dark:text-gray-400">Thread history</h3>
          <div class="mt-3 space-y-3">
            <% thread_timeline.each do |entry| %>
              <% active_entry = entry[:kind] == :outbound && entry[:record] == outbound_message %>
              <div class="rounded-2xl border px-4 py-4 <%= active_entry ? 'border-blue-300 bg-blue-50 dark:border-blue-700 dark:bg-blue-950/40' : 'border-gray-200 bg-gray-50/80 dark:border-gray-700 dark:bg-gray-900/50' %>">
                <div class="flex items-start justify-between gap-4">
                  <div>
                    <p class="text-xs font-semibold uppercase tracking-[0.16em] text-gray-500 dark:text-gray-400"><%= entry[:kind] == :inbound ? 'Inbound' : 'Outbound' %></p>
                    <p class="mt-1 text-sm font-medium text-gray-900 dark:text-white"><%= entry[:sender] %></p>
                    <p class="mt-1 text-xs text-gray-500 dark:text-gray-400"><%= Array(entry[:recipients]).join(', ').presence || 'No recipients' %></p>
                  </div>
                  <div class="text-right">
                    <p class="text-xs text-gray-500 dark:text-gray-400"><%= l(entry[:occurred_at], format: :long) %></p>
                    <p class="mt-1 text-xs font-medium text-gray-600 dark:text-gray-300"><%= entry[:status] %></p>
                  </div>
                </div>
                <p class="mt-3 text-sm text-gray-700 dark:text-gray-200"><%= truncate(entry[:summary], length: 180) %></p>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="flex h-full flex-col items-center justify-center px-8 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">Sent</p>
      <h2 class="mt-3 text-2xl font-semibold text-gray-900 dark:text-white">Select a sent message</h2>
      <p class="mt-2 max-w-md text-sm text-gray-500 dark:text-gray-400">Choose a sent message to inspect the body and manage its conversation labels.</p>
    </div>
  <% end %>
</div>
