<% content_for :title, "InboxOS" %>
<% content_for :main_class, "mx-auto my-6 w-full max-w-7xl px-4 sm:px-6 lg:px-8" %>
<div class="grid min-h-[calc(100vh-8rem)] grid-cols-1 gap-4 lg:grid-cols-[16rem_24rem_minmax(0,1fr)]">
  <aside class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
    <%= render "sidebar", inboxes: @inboxes, selected_inbox: @selected_inbox, all_inboxes_count: @all_inboxes_count %>
  </aside>
  <section class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
    <%= render "message_list", messages: @messages, pagy: @pagy, selected_message: @selected_message, selected_inbox: @selected_inbox %>
  </section>
  <section class="overflow-hidden rounded-3xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-800">
    <%= render "message_detail", message: @selected_message %>
  </section>
</div>
