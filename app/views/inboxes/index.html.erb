<% content_for :title, "InboxOS" %>
<% content_for :main_class, "w-full" %>
<div class="grid min-h-[calc(100vh-4.5625rem)] grid-cols-1 <%= @outbound_message.present? ? 'xl:grid-cols-[18rem_28rem_minmax(0,1fr)_32rem]' : 'xl:grid-cols-[18rem_30rem_minmax(0,1fr)]' %>">
  <aside class="overflow-hidden border-b border-gray-200 bg-white xl:border-b-0 xl:border-r dark:border-gray-700 dark:bg-gray-800">
    <%= render "inboxes/sidebar", inboxes: @inboxes, selected_inbox: @selected_inbox, all_inboxes_count: @all_inboxes_count %>
  </aside>
  <section class="overflow-hidden border-b border-gray-200 bg-white xl:border-b-0 xl:border-r dark:border-gray-700 dark:bg-gray-800">
    <%= render "inboxes/message_list", messages: @messages, pagy: @pagy, selected_message: @selected_message, selected_inbox: @selected_inbox %>
  </section>
  <section class="overflow-hidden bg-white dark:bg-gray-800">
    <%= render "inboxes/message_detail", message: @selected_message, thread_timeline: @thread_timeline %>
  </section>
  <% if @outbound_message.present? %>
    <section class="overflow-hidden border-t border-gray-200 bg-white xl:border-t-0 xl:border-l dark:border-gray-700 dark:bg-gray-800">
      <%= render "outbound_messages/compose_pane", outbound_message: @outbound_message, selected_inbox: @selected_inbox, selected_message: @selected_message %>
    </section>
  <% end %>
</div>
