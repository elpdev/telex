<% unread = message.unread_for?(Current.user) %>
<% starred = message.starred_for?(Current.user) %>
<%= link_to root_path(inbox_browser_params({message_id: message.id}, except: [:attachment_id, :outbound_attachment_id, :sent_attachment_id])), class: token_list("block border-l-2 px-5 py-4 transition", selected ? "border-blue-500 bg-blue-50 dark:bg-blue-900/20" : unread ? "border-blue-400 hover:bg-gray-50 dark:hover:bg-gray-700/50" : "border-transparent hover:bg-gray-50 dark:hover:bg-gray-700/50") do %>
  <div class="flex items-start justify-between gap-3">
    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2">
        <p class="truncate text-sm <%= unread ? 'font-semibold text-gray-900 dark:text-white' : 'font-medium text-gray-700 dark:text-gray-200' %>"><%= message.subject.presence || "(no subject)" %></p>
        <% if starred %>
          <%= render Badge::Component.new(text: "Starred", variant: :warning, size: :small) %>
        <% end %>
        <% if message.subaddress.present? %>
          <%= render Badge::Component.new(text: "+#{message.subaddress}", variant: :info, size: :small) %>
        <% end %>
        <% if unread %>
          <%= render Badge::Component.new(text: "Unread", variant: :primary, size: :small) %>
        <% end %>
      </div>
      <p class="mt-1 truncate text-sm <%= unread ? 'text-gray-700 dark:text-gray-200' : 'text-gray-600 dark:text-gray-300' %>"><%= message.sender_display %></p>
      <p class="mt-2 line-clamp-2 text-sm <%= unread ? 'text-gray-600 dark:text-gray-300' : 'text-gray-500 dark:text-gray-400' %>"><%= message.preview_text %></p>
    </div>
    <div class="shrink-0 text-right">
      <p class="text-xs <%= unread ? 'font-semibold text-gray-700 dark:text-gray-200' : 'font-medium text-gray-500 dark:text-gray-400' %>"><%= relative_message_time(message) %></p>
      <p class="mt-2 text-xs text-gray-400 dark:text-gray-500"><%= message.inbox.local_part %></p>
    </div>
  </div>
<% end %>
