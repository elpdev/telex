<div class="<%= card_classes %>">
  <% if title.present? %>
    <span class="absolute -top-2 left-4 bg-bg px-2 font-mono text-[0.65rem] uppercase tracking-widest text-phosphor">
      <%= bracketed_title %>
    </span>
  <% end %>
  <% if subtitle.present? %>
    <div class="border-b border-hairline px-5 py-2">
      <p class="font-mono text-[0.7rem] uppercase tracking-widest text-phosphor-dim"><%= subtitle %></p>
    </div>
  <% end %>
  <div class="<%= body_classes %>">
    <%= content %>
  </div>
  <% if footer && footer_content? %>
    <div class="border-t border-hairline px-5 py-3">
      <%= footer_content %>
    </div>
  <% end %>
</div>
