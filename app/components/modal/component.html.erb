<div data-controller="modal">
  <% if trigger? %>
    <div data-action="click->modal#show">
      <%= trigger %>
    </div>
  <% end %>

  <dialog class="<%= dialog_classes %>" data-modal-target="dialog" data-action="<%= backdrop_action %>">
    <div class="flex flex-col p-6 gap-4">
      <% if title.present? %>
        <header class="flex items-center justify-between">
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white"><%= title %></h3>
          <button type="button" data-action="modal#close" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-300">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </header>
      <% end %>

      <div>
        <%= content %>
      </div>

      <% if footer_content? %>
        <footer class="flex items-center justify-end gap-2 pt-4 border-t border-gray-200 dark:border-gray-700">
          <%= footer_content %>
        </footer>
      <% end %>
    </div>
  </dialog>
</div>
