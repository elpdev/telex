<div data-controller="modal">
  <% if trigger? %>
    <div data-action="click->modal#show">
      <%= trigger %>
    </div>
  <% end %>

  <dialog class="<%= dialog_classes %>" data-modal-target="dialog" data-action="<%= backdrop_action %>">
    <div class="flex flex-col">
      <header class="flex items-center justify-between border-b border-hairline px-5 py-3">
        <span class="font-mono text-xs uppercase tracking-widest text-phosphor">
          <%= bracketed_title || "[ DIALOG ]" %>
        </span>
        <button type="button" data-action="modal#close" class="font-mono text-xs uppercase tracking-wider text-phosphor-dim hover:text-amber">
          [ X ]
        </button>
      </header>

      <div class="px-5 py-5 text-sm text-phosphor">
        <%= content %>
      </div>

      <% if footer_content? %>
        <footer class="flex items-center justify-end gap-3 border-t border-hairline px-5 py-3">
          <%= footer_content %>
        </footer>
      <% end %>
    </div>
  </dialog>
</div>
